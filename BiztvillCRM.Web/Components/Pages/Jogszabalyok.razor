@page "/jogszabalyok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@inject IJogszabalyService JogszabalyService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Jogszabályok</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Jogszabályok</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (szám, cím)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új jogszabály</MudButton>
    </MudStack>

    <MudDataGrid T="Jogszabaly" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="j => j.Szam" Title="Szám" />
            <PropertyColumn Property="j => j.Cim" Title="Cím" />
            <PropertyColumn Property="j => j.HatalyosDatum" Title="Hatályos" Format="yyyy.MM.dd" />
            <TemplateColumn Title="Link">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.Url))
                    {
                        <MudLink Href="@context.Item.Url" Target="_blank">Megnyitás</MudLink>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető jogszabály.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Jogszabály szerkesztése" : "Új jogszabály")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Szam" Label="Szám *" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_hatalyosDatum" Label="Hatályos dátum" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Cim" Label="Cím *" Required="true" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Url" Label="URL" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Megjegyzes" Label="Megjegyzés" Lines="2" /></MudItem>
                <MudItem xs="12"><MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Jogszabaly> _lista = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private Jogszabaly? _szerkesztesAlatt;
    private DateTime? _hatalyosDatum;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<Jogszabaly> _szurtLista => string.IsNullOrWhiteSpace(_kereses) ? _lista
        : _lista.Where(j => (j.Szam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (j.Cim?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await BetoltesAsync();
    private async Task BetoltesAsync() { _betoltes = true; _lista = await JogszabalyService.GetAllAsync(); _betoltes = false; }

    private void UjMegnyitasa() { _szerkesztesAlatt = new Jogszabaly { Aktiv = true }; _hatalyosDatum = null; _dialogNyitva = true; }
    private void SzerkesztesMegnyitasa(Jogszabaly item) { _szerkesztesAlatt = new Jogszabaly { Id = item.Id, Szam = item.Szam, Cim = item.Cim, Url = item.Url, Megjegyzes = item.Megjegyzes, Aktiv = item.Aktiv }; _hatalyosDatum = item.HatalyosDatum; _dialogNyitva = true; }
    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Szam) || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Cim))
        { Snackbar.Add("A szám és cím megadása kötelező!", Severity.Warning); return; }
        _szerkesztesAlatt.HatalyosDatum = _hatalyosDatum;
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await JogszabalyService.CreateAsync(_szerkesztesAlatt);
            else await JogszabalyService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success); DialogBezarasa(); await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Jogszabaly item)
    {
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli: \"{item.Szam}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await JogszabalyService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }
}