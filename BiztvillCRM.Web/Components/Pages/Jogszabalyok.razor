@page "/jogszabalyok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Shared.Enums
@using BiztvillCRM.Services.Interfaces
@inject IJogszabalyService JogszabalyService
@inject ITenantService TenantService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Jogszabályok és Szabványok</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Jogszabályok és Szabványok</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (szám, cím, leírás)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:300px;" />
        <MudSelect T="TevekenysegTipus?" @bind-Value="_szuroTerulet" Label="Terület szűrés" Clearable="true" Style="max-width:200px;">
            <MudSelectItem T="TevekenysegTipus?" Value="@((TevekenysegTipus?)null)">Mind</MudSelectItem>
            <MudSelectItem T="TevekenysegTipus?" Value="@TevekenysegTipus.VillanosMeres">Villamos biztonságtechnika</MudSelectItem>
            <MudSelectItem T="TevekenysegTipus?" Value="@TevekenysegTipus.Benzinkuttechnika">Benzinkúttechnika</MudSelectItem>
        </MudSelect>
        <MudSpacer />
        @if (_isAdmin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új jogszabály/szabvány</MudButton>
        }
        else
        {
            <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Info">Csak megtekintés</MudChip>
        }
    </MudStack>

    <MudDataGrid T="Jogszabaly" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <TemplateColumn Title="Típus" Sortable="true">
                <CellTemplate>
                    @if (context.Item.Tipus == JogszabalyTipus.Szabvany)
                    {
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.MenuBook"
                                 Style="background-color: #00897B; color: white;">
                            Szabvány
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Gavel"
                                 Style="background-color: #E65100; color: white;">
                            Jogszabály
                        </MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="j => j.Szam" Title="Szám" />
            <PropertyColumn Property="j => j.Cim" Title="Cím" />
            <TemplateColumn Title="Terület">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        @if (context.Item.Terulet.HasFlag(TevekenysegTipus.VillanosMeres))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.ElectricBolt">Villamos</MudChip>
                        }
                        @if (context.Item.Terulet.HasFlag(TevekenysegTipus.Benzinkuttechnika))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Icon="@Icons.Material.Filled.LocalGasStation">Benzinkút</MudChip>
                        }
                        @if (context.Item.Terulet == TevekenysegTipus.Nincs)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Általános</MudChip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="j => j.HatalyosKezdet" Title="Hatályos (kezdet)" Format="yyyy.MM.dd" />
            <TemplateColumn Title="Hatályos (vége)">
                <CellTemplate>
                    @if (context.Item.HatalyosVege.HasValue)
                    {
                        @context.Item.HatalyosVege.Value.ToString("yyyy.MM.dd")
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Jelenleg hatályos</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <!-- ÚJ: Megjegyzés oszlop -->
            <TemplateColumn Title="Megj.">
                <CellTemplate>
                    @if (!string.IsNullOrWhiteSpace(context.Item.Megjegyzes))
                    {
                        <MudTooltip Text="Kattints a megjegyzés megtekintéséhez">
                            <MudIconButton Icon="@Icons.Material.Filled.Comment" 
                                           Color="Color.Info" 
                                           Size="Size.Small" 
                                           OnClick="() => MegjegyzesMegnyitasa(context.Item)" />
                        </MudTooltip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Link">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.Url))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Href="@context.Item.Url" Target="_blank" Size="Size.Small" Color="Color.Info" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            @if (_isAdmin)
            {
                <TemplateColumn Title="Műveletek" Sortable="false">
                    <CellTemplate>
                        <MudStack Row="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető jogszabály vagy szabvány.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<!-- ÚJ: Megjegyzés dialógus -->
<MudDialog @bind-Visible="_megjegyzesDialogNyitva" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Comment" Color="Color.Info" Class="mr-2" />
            <MudText Typo="Typo.h6">@_megjegyzesJogszabaly?.Szam</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">@_megjegyzesJogszabaly?.Cim</MudText>
        <MudDivider Class="mb-3" />
        <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_megjegyzesJogszabaly?.Megjegyzes</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _megjegyzesDialogNyitva = false" Color="Color.Primary">Bezárás</MudButton>
    </DialogActions>
</MudDialog>

<!-- Szerkesztés dialógus (meglévő) -->
<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Szerkesztés" : "Új jogszabály/szabvány")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="JogszabalyTipus" @bind-Value="_szerkesztesAlatt.Tipus" Label="Típus *">
                        @foreach (JogszabalyTipus t in Enum.GetValues(typeof(JogszabalyTipus)))
                        {
                            <MudSelectItem Value="@t">@t</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Szam" Label="Szám *" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Cim" Label="Cím *" Required="true" /></MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Class="mb-2">Terület (több is kiválasztható)</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudCheckBox T="bool" Value="@_villamosMeres" ValueChanged="@((bool v) => TeruletValtozas(TevekenysegTipus.VillanosMeres, v))"
                                     Label="Villamos biztonságtechnika" Color="Color.Warning" />
                        <MudCheckBox T="bool" Value="@_benzinkuttechnika" ValueChanged="@((bool v) => TeruletValtozas(TevekenysegTipus.Benzinkuttechnika, v))"
                                     Label="Benzinkúttechnika" Color="Color.Secondary" />
                    </MudStack>
                </MudItem>
                
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Leiras" Label="Leírás" Lines="3" /></MudItem>
                <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_hatalyosKezdet" Label="Hatályos kezdete" /></MudItem>
                <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_hatalyosVege" Label="Hatályos vége (üres = jelenleg hatályos)" Clearable="true" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Url" Label="URL (link)" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Megjegyzes" Label="Megjegyzés" Lines="2" /></MudItem>
                <MudItem xs="12"><MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Jogszabaly> _lista = new();
    private string _kereses = string.Empty;
    private TevekenysegTipus? _szuroTerulet;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private bool _isAdmin;
    private Jogszabaly? _szerkesztesAlatt;
    private DateTime? _hatalyosKezdet, _hatalyosVege;
    private bool _villamosMeres, _benzinkuttechnika;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<Jogszabaly> _szurtLista
    {
        get
        {
            var lista = _lista.AsEnumerable();
            
            // Szöveges keresés
            if (!string.IsNullOrWhiteSpace(_kereses))
            {
                lista = lista.Where(j => (j.Szam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                         (j.Cim?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                         (j.Leiras?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            
            // Terület szűrés
            if (_szuroTerulet.HasValue)
            {
                lista = lista.Where(j => j.Terulet.HasFlag(_szuroTerulet.Value));
            }
            
            return lista;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = TenantService.IsInRole(FelhasznaloSzerepkor.Admin);
        await BetoltesAsync();
    }

    private async Task BetoltesAsync()
    {
        _betoltes = true;
        try { _lista = await JogszabalyService.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _betoltes = false; }
    }

    private void UjMegnyitasa()
    {
        if (!_isAdmin) return;
        _szerkesztesAlatt = new Jogszabaly { Aktiv = true };
        _hatalyosKezdet = DateTime.Today;
        _hatalyosVege = null;
        _villamosMeres = false;
        _benzinkuttechnika = false;
        _dialogNyitva = true;
    }

    private void SzerkesztesMegnyitasa(Jogszabaly item)
    {
        if (!_isAdmin) return;
        _szerkesztesAlatt = new Jogszabaly
        {
            Id = item.Id,
            Szam = item.Szam,
            Cim = item.Cim,
            Leiras = item.Leiras,
            Tipus = item.Tipus,
            Terulet = item.Terulet,
            Url = item.Url,
            Megjegyzes = item.Megjegyzes,
            Aktiv = item.Aktiv
        };
        _hatalyosKezdet = item.HatalyosKezdet;
        _hatalyosVege = item.HatalyosVege;
        _villamosMeres = item.Terulet.HasFlag(TevekenysegTipus.VillanosMeres);
        _benzinkuttechnika = item.Terulet.HasFlag(TevekenysegTipus.Benzinkuttechnika);
        _dialogNyitva = true;
    }

    private void TeruletValtozas(TevekenysegTipus tipus, bool ertek)
    {
        if (_szerkesztesAlatt is null) return;
        
        if (tipus == TevekenysegTipus.VillanosMeres) _villamosMeres = ertek;
        if (tipus == TevekenysegTipus.Benzinkuttechnika) _benzinkuttechnika = ertek;
        
        // Flags enum frissítése
        _szerkesztesAlatt.Terulet = TevekenysegTipus.Nincs;
        if (_villamosMeres) _szerkesztesAlatt.Terulet |= TevekenysegTipus.VillanosMeres;
        if (_benzinkuttechnika) _szerkesztesAlatt.Terulet |= TevekenysegTipus.Benzinkuttechnika;
    }

    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (!_isAdmin) { Snackbar.Add("Nincs jogosultsága!", Severity.Error); return; }
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Szam) || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Cim))
        {
            Snackbar.Add("A szám és cím megadása kötelező!", Severity.Warning);
            return;
        }
        _szerkesztesAlatt.HatalyosKezdet = _hatalyosKezdet;
        _szerkesztesAlatt.HatalyosVege = _hatalyosVege;
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await JogszabalyService.CreateAsync(_szerkesztesAlatt);
            else await JogszabalyService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success);
            DialogBezarasa();
            await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Jogszabaly item)
    {
        if (!_isAdmin) { Snackbar.Add("Nincs jogosultsága!", Severity.Error); return; }
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli: \"{item.Szam}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await JogszabalyService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }

    // ÚJ: Megjegyzés megjelenítése
    private Jogszabaly? _megjegyzesJogszabaly;
    private bool _megjegyzesDialogNyitva = false;

    private void MegjegyzesMegnyitasa(Jogszabaly jogszabaly)
    {
        _megjegyzesJogszabaly = jogszabaly;
        _megjegyzesDialogNyitva = true;
    }
}