@page "/hatosagok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@inject IHatosagService HatosagService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Hatóságok</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Hatóságok</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (név, rövidítés)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új hatóság</MudButton>
    </MudStack>

    <MudDataGrid T="Hatosag" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="h => h.Nev" Title="Név" />
            <PropertyColumn Property="h => h.Rovidites" Title="Rövidítés" />
            <PropertyColumn Property="h => h.Cim" Title="Cím" />
            <PropertyColumn Property="h => h.Weboldal" Title="Weboldal" />
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető hatóság.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Hatóság szerkesztése" : "Új hatóság")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Nev" Label="Név *" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Rovidites" Label="Rövidítés" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Cim" Label="Cím" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Weboldal" Label="Weboldal" /></MudItem>
                <MudItem xs="12"><MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Hatosag> _lista = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private Hatosag? _szerkesztesAlatt;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<Hatosag> _szurtLista => string.IsNullOrWhiteSpace(_kereses) ? _lista
        : _lista.Where(h => (h.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (h.Rovidites?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await BetoltesAsync();
    private async Task BetoltesAsync() { _betoltes = true; _lista = await HatosagService.GetAllAsync(); _betoltes = false; }

    private void UjMegnyitasa() { _szerkesztesAlatt = new Hatosag { Aktiv = true }; _dialogNyitva = true; }
    private void SzerkesztesMegnyitasa(Hatosag item) { _szerkesztesAlatt = new Hatosag { Id = item.Id, Nev = item.Nev, Rovidites = item.Rovidites, Cim = item.Cim, Weboldal = item.Weboldal, Aktiv = item.Aktiv }; _dialogNyitva = true; }
    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev)) { Snackbar.Add("A név megadása kötelező!", Severity.Warning); return; }
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await HatosagService.CreateAsync(_szerkesztesAlatt);
            else await HatosagService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success); DialogBezarasa(); await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Hatosag item)
    {
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli: \"{item.Nev}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await HatosagService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }
}