@page "/meresek"
@attribute [Authorize(Policy = "RequireMeresek")]
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Shared.Enums
@using BiztvillCRM.Services.Interfaces
@inject IMeresService MeresService
@inject IUgyfelService UgyfelService
@inject ITelephelyService TelephelyService
@inject IMeresTipusService MeresTipusService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJegyzokonyvPdfService JegyzokonyvPdfService
@inject IJegyzokonyvWordService JegyzokonyvWordService
@inject IJSRuntime JS
@inject IEmailKuldoService EmailKuldoService
@inject ITenantService TenantService

<PageTitle>Mérések</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Mérések</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (ügyfél, telephely, eredmény)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új mérés</MudButton>
    </MudStack>

    <MudDataGrid T="Meres" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="m => m.Ugyfel!.Nev" Title="Ügyfél" />
            <PropertyColumn Property="m => m.Telephely!.Nev" Title="Telephely" />
            <PropertyColumn Property="m => m.MeresTipus!.Nev" Title="Típus" />
            <PropertyColumn Property="m => m.Datum" Title="Dátum" Format="yyyy.MM.dd" />
            <PropertyColumn Property="m => m.KovetkezoDatum" Title="Következő" Format="yyyy.MM.dd" />
            <PropertyColumn Property="m => m.Eredmeny" Title="Eredmény" />
            <PropertyColumn Property="m => m.MeresStatusz" Title="Státusz" />
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Word jegyzőkönyv">
                            <MudIconButton Icon="@Icons.Material.Filled.Description" 
                                           Color="Color.Info" 
                                           Size="Size.Small" 
                                           OnClick="() => WordLetoltesAsync(context.Item)" />
                        </MudTooltip>
                        <MudTooltip Text="Email küldése">
                            <MudIconButton Icon="@Icons.Material.Filled.Email" 
                                           Color="Color.Secondary" 
                                           Size="Size.Small" 
                                           OnClick="() => EmailKuldesDialogusMegnyitasa(context.Item)" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                       Color="Color.Primary" 
                                       Size="Size.Small" 
                                       OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                       Color="Color.Error" 
                                       Size="Size.Small" 
                                       OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető mérés.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<!-- Email küldés dialógus -->
<MudDialog @bind-Visible="_emailDialogNyitva" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
            Email értesítés küldése
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_emailMeres is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                <b>@_emailMeres.Ugyfel?.Nev</b> - @_emailMeres.MeresTipus?.Nev<br/>
                Következő: @_emailMeres.KovetkezoDatum?.ToString("yyyy.MM.dd")
            </MudAlert>

            <MudSelect T="EmailErtesitesTipus" @bind-Value="_kivalasztottEmailTipus" Label="Értesítés típusa *" Required="true" Class="mb-3">
                <MudSelectItem Value="EmailErtesitesTipus.MeresLejarat90Nap">Mérés lejárat - 90 nap</MudSelectItem>
                <MudSelectItem Value="EmailErtesitesTipus.MeresLejarat30Nap">Mérés lejárat - 30 nap</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_emailCimzett" Label="Címzett email cím *" Required="true" 
                          InputType="InputType.Email" HelperText="Az ügyfél vagy telephely email címe" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _emailDialogNyitva = false">Mégse</MudButton>
        <MudButton OnClick="EmailKuldesAsync" Color="Color.Primary" Variant="Variant.Filled" 
                   Disabled="_emailKuldes" StartIcon="@Icons.Material.Filled.Send">
            @(_emailKuldes ? "Küldés..." : "Küldés")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Mérés szerkesztése" : "Új mérés")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Value="_szerkesztesAlatt.UgyfelId" Label="Ügyfél *" 
                               ValueChanged="@((int id) => UgyfelValtozottAsync(id))"
                               ToStringFunc="@(id => _ugyfelek.FirstOrDefault(u => u.Id == id)?.Nev ?? "")">
                        @foreach (var u in _ugyfelek)
                        {
                            <MudSelectItem Value="@u.Id">@u.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_szerkesztesAlatt.TelephelyId" Label="Telephely *"
                               Disabled="@(_szurtTelephelyek.Count == 0)"
                               ToStringFunc="@(id => _szurtTelephelyek.FirstOrDefault(t => t.Id == id)?.Nev ?? "")">
                        @foreach (var t in _szurtTelephelyek)
                        {
                            <MudSelectItem Value="@t.Id">@t.Nev (@t.Cim)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Value="_szerkesztesAlatt.MeresTipusId" 
                               ValueChanged="OnMeresTipusValtozas"
                               Label="Típus *"
                               ToStringFunc="@(id => _tipusok.FirstOrDefault(t => t.Id == id)?.Nev ?? "")">
                        @foreach (var t in _tipusok)
                        {
                            <MudSelectItem Value="@t.Id">@t.Nev @(t.ErvenyessegHonap.HasValue && t.ErvenyessegHonap > 0 ? $"({t.ErvenyessegHonap} hónap)" : "")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6"><MudDatePicker Date="_datum" DateChanged="OnDatumValtozas" Label="Dátum *" /></MudItem>
                <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_kovetkezoDatum" Label="Következő dátum (auto)" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.body2" Class="mb-1">Eredmény</MudText>
                    <MudToggleGroup T="string" @bind-Value="_szerkesztesAlatt.Eredmeny" 
                                    Color="Color.Primary" 
                                    Rounded="true" 
                                    CheckMark="true">
                        <MudToggleItem Value="@("MEGFELELT")" Text="Megfelelt" />
                        <MudToggleItem Value="@("NEM MEGFELELT")" Text="Nem megfelelt" />
                    </MudToggleGroup>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="MeresStatusz" @bind-Value="_szerkesztesAlatt.MeresStatusz" Label="Státusz">
                        @foreach (MeresStatusz s in Enum.GetValues(typeof(MeresStatusz)))
                        {
                            <MudSelectItem Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Megjegyzes" Label="Megjegyzés" Lines="2" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Meres> _lista = new();
    private List<Ugyfel> _ugyfelek = new();
    private List<Telephely> _telephelyek = new();
    private List<Telephely> _szurtTelephelyek = new();
    private List<MeresTipus> _tipusok = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private Meres? _szerkesztesAlatt;
    
    // HIÁNYZÓ DEKLARÁCIÓK:
    private int _cegId;
    private int _kivalasztottUgyfelId;
    private DateTime? _datum;
    private DateTime? _kovetkezoDatum;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
    
    // Email küldés
    private bool _emailDialogNyitva = false;
    private bool _emailKuldes = false;
    private Meres? _emailMeres;
    private EmailErtesitesTipus _kivalasztottEmailTipus = EmailErtesitesTipus.MeresLejarat90Nap;
    private string _emailCimzett = "";

    private IEnumerable<Meres> _szurtLista => string.IsNullOrWhiteSpace(_kereses) ? _lista
        : _lista.Where(m => (m.Ugyfel?.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (m.Telephely?.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (m.Eredmeny?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        _cegId = TenantService.GetCurrentCegId();
        
        // HIÁNYZÓ BETÖLTÉSEK:
        _ugyfelek = await UgyfelService.GetAllAsync();
        _telephelyek = await TelephelyService.GetAllAsync();
        _tipusok = await MeresTipusService.GetAllAsync();
        
        await BetoltesAsync();
    }

    private async Task BetoltesAsync() { _betoltes = true; _lista = await MeresService.GetAllAsync(); _betoltes = false; }

    private void UjMegnyitasa() 
    { 
        var elsoTipus = _tipusok.FirstOrDefault();
        
        _szerkesztesAlatt = new Meres 
        { 
            MeresTipusId = elsoTipus?.Id ?? 0
        }; 
        _datum = DateTime.Today; 
        _kovetkezoDatum = null; 
        _kivalasztottUgyfelId = 0;
        _szurtTelephelyek = new();
        
        // Következő dátum számolása rögtön
        SzamolKovetkezoDatum();
        
        _dialogNyitva = true; 
    }

    private void SzerkesztesMegnyitasa(Meres item) 
    { 
        _szerkesztesAlatt = new Meres 
        { 
            Id = item.Id, 
            UgyfelId = item.UgyfelId,
            TelephelyId = item.TelephelyId, 
            MeresTipusId = item.MeresTipusId, 
            Eredmeny = item.Eredmeny, 
            MeresStatusz = item.MeresStatusz, 
            Megjegyzes = item.Megjegyzes 
        }; 
        _kivalasztottUgyfelId = item.UgyfelId;
        _szurtTelephelyek = _telephelyek.Where(t => t.UgyfelId == _kivalasztottUgyfelId).ToList();
        _datum = item.Datum; 
        _kovetkezoDatum = item.KovetkezoDatum; 
        _dialogNyitva = true; 
    }

    private Task UgyfelValtozottAsync(int ugyfelId)
    {
        _kivalasztottUgyfelId = ugyfelId;
        _szurtTelephelyek = _telephelyek.Where(t => t.UgyfelId == ugyfelId).ToList();
        if (_szerkesztesAlatt is not null)
        {
            _szerkesztesAlatt.UgyfelId = ugyfelId;
            _szerkesztesAlatt.TelephelyId = _szurtTelephelyek.FirstOrDefault()?.Id ?? 0;
        }
        return Task.CompletedTask;
    }

    private void OnMeresTipusValtozas(int ujTipusId)
    {
        if (_szerkesztesAlatt != null)
        {
            _szerkesztesAlatt.MeresTipusId = ujTipusId;
            SzamolKovetkezoDatum();
        }
    }

    private void OnDatumValtozas(DateTime? ujDatum)
    {
        _datum = ujDatum;
        SzamolKovetkezoDatum();
    }

    /// <summary>Automatikusan kiszámolja a következő mérés dátumát a típus érvényességi ideje alapján.</summary>
    private void SzamolKovetkezoDatum()
    {
        if (_szerkesztesAlatt == null || _datum == null || _szerkesztesAlatt.MeresTipusId == 0) 
            return;

        var tipus = _tipusok.FirstOrDefault(t => t.Id == _szerkesztesAlatt.MeresTipusId);
        if (tipus != null && tipus.ErvenyessegHonap.HasValue && tipus.ErvenyessegHonap > 0)
        {
            _kovetkezoDatum = _datum.Value.AddMonths(tipus.ErvenyessegHonap.Value);
            StateHasChanged();
        }
    }

    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || _datum is null) { Snackbar.Add("A dátum megadása kötelező!", Severity.Warning); return; }
        if (_szerkesztesAlatt.UgyfelId == 0) { Snackbar.Add("Az ügyfél kiválasztása kötelező!", Severity.Warning); return; }
        if (_szerkesztesAlatt.TelephelyId == 0) { Snackbar.Add("A telephely kiválasztása kötelező!", Severity.Warning); return; }
        if (_szerkesztesAlatt.MeresTipusId == 0) { Snackbar.Add("A típus kiválasztása kötelező!", Severity.Warning); return; }
        
        _szerkesztesAlatt.Datum = _datum.Value;
        _szerkesztesAlatt.KovetkezoDatum = _kovetkezoDatum;
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await MeresService.CreateAsync(_szerkesztesAlatt);
            else await MeresService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success); DialogBezarasa(); await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Meres item)
    {
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli ezt a mérést?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await MeresService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }

    private async Task JegyzokonyvLetoltesAsync(Meres meres)
    {
        try
        {
            var pdfBytes = await JegyzokonyvPdfService.GeneralasAsync(meres.Id);
            var fileName = $"jegyzokonyv_{meres.Id}_{DateTime.Now:yyyyMMdd}.pdf";
            
            // Letöltés böngészőben
            using var streamRef = new DotNetStreamReference(new MemoryStream(pdfBytes));
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            
            Snackbar.Add("Jegyzőkönyv letöltve!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
    }

    private async Task WordLetoltesAsync(Meres meres)
    {
        try
        {
            var wordBytes = await JegyzokonyvWordService.GeneralasAsync(meres.Id);
            var fileName = $"jegyzokonyv_{meres.Id:D6}_{DateTime.Now:yyyyMMdd}.docx";
            
            using var streamRef = new DotNetStreamReference(new MemoryStream(wordBytes));
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            
            Snackbar.Add("Word jegyzőkönyv letöltve!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
    }

    private async Task EmailKuldesDialogusMegnyitasa(Meres meres)
    {
        _emailMeres = meres;
        _kivalasztottEmailTipus = EmailErtesitesTipus.MeresLejarat90Nap;
        _emailCimzett = meres.Telephely?.Email ?? meres.Ugyfel?.Email ?? "";
        _emailDialogNyitva = true;
    }

    private async Task EmailKuldesAsync()
    {
        if (_emailMeres is null || string.IsNullOrWhiteSpace(_emailCimzett))
        {
            Snackbar.Add("Kérjük adja meg a címzett email címét!", Severity.Warning);
            return;
        }

        _emailKuldes = true;
        try
        {
            var placeholderek = new Dictionary<string, string>
            {
                { "UgyfelNev", _emailMeres.Ugyfel?.Nev ?? "" },
                { "TelephelyNev", _emailMeres.Telephely?.Nev ?? "" },
                { "MeresTipus", _emailMeres.MeresTipus?.Nev ?? "" },
                { "LejaratDatum", _emailMeres.KovetkezoDatum?.ToString("yyyy.MM.dd") ?? "" },
                { "EszkozTipus", "" },
                { "CegNev", "" }
            };

            var siker = await EmailKuldoService.KuldSablonbolAsync(
                _kivalasztottEmailTipus,
                _emailCimzett,
                placeholderek,
                _cegId,
                meresId: _emailMeres.Id
            );

            if (siker)
            {
                Snackbar.Add($"Email sikeresen elküldve: {_emailCimzett}", Severity.Success);
                _emailDialogNyitva = false;
            }
            else
            {
                Snackbar.Add("Email küldése sikertelen! Ellenőrizd az SMTP beállításokat.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
        finally
        {
            _emailKuldes = false;
        }
    }
}