    // === SABLON KEZELÉS ===
    
    private void UjSablonLetrehozasa()
    {
        _szerkesztettSablon = new EmailSablon
        {
            CegId = _isAdmin ? null : _cegId,  // Admin: globális (null), Nem-admin: saját cég
            Aktiv = true,
            Tipus = EmailErtesitesTipus.HitelesitesLejarat90Nap
        };
        _sablonDialogNyitva = true;
    }

    private void SablonSzerkesztes(EmailSablon sablon)
    {
        _szerkesztettSablon = new EmailSablon
        {
            Id = sablon.Id,
            Nev = sablon.Nev,
            Tipus = sablon.Tipus,
            Targy = sablon.Targy,
            Szoveg = sablon.Szoveg,
            Aktiv = sablon.Aktiv,
            CegId = sablon.CegId
        };
        _sablonDialogNyitva = true;
    }

    private void SablonMasolasa(EmailSablon sablon)
    {
        _szerkesztettSablon = new EmailSablon
        {
            Nev = $"{sablon.Nev} (saját)",
            Tipus = sablon.Tipus,
            Targy = sablon.Targy,
            Szoveg = sablon.Szoveg,
            Aktiv = true,
            CegId = _cegId
        };
        _sablonDialogNyitva = true;
    }

    private async Task SablonMentesAsync()
    {
        if (_szerkesztettSablon is null || string.IsNullOrWhiteSpace(_szerkesztettSablon.Nev))
        {
            Snackbar.Add("A sablon neve kötelező!", Severity.Warning);
            return;
        }

        _mentes = true;
        try
        {
            // Admin mindig globális sablont ment (CegId = null)
            if (_isAdmin)
            {
                _szerkesztettSablon.CegId = null;
            }

            if (_szerkesztettSablon.Id == 0)
            {
                await SablonService.CreateAsync(_szerkesztettSablon);
                Snackbar.Add(_isAdmin ? "Globális sablon létrehozva!" : "Sablon létrehozva!", Severity.Success);
            }
            else
            {
                await SablonService.UpdateAsync(_szerkesztettSablon);
                Snackbar.Add("Sablon mentve!", Severity.Success);
            }
            _sablonDialogNyitva = false;
            await BetoltesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
        finally { _mentes = false; }
    }

    private async Task SablonTorlesAsync(EmailSablon sablon)
    {
        // Admin csak globális sablonot törölhet, nem-admin csak sajátot
        if (_isAdmin && sablon.CegId is not null)
        {
            Snackbar.Add("Admin csak globális sablont törölhet!", Severity.Warning);
            return;
        }
        if (!_isAdmin && sablon.CegId != _cegId)
        {
            Snackbar.Add("Csak saját sablont törölhet!", Severity.Warning);
            return;
        }

        try
        {
            await SablonService.DeleteAsync(sablon.Id);
            Snackbar.Add("Sablon törölve!", Severity.Success);
            await BetoltesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
    }

    private static string GetTipusNev(EmailErtesitesTipus tipus) => tipus switch
    {
        EmailErtesitesTipus.HitelesitesLejarat90Nap => "Hitelesítés - 90 nap",
        EmailErtesitesTipus.HitelesitesLejarat30Nap => "Hitelesítés - 30 nap",
        EmailErtesitesTipus.MeresLejarat90Nap => "Mérés - 90 nap",
        EmailErtesitesTipus.MeresLejarat30Nap => "Mérés - 30 nap",
        _ => tipus.ToString()
    };
