@page "/eszkozok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@inject IEszkozService EszkozService
@inject IGyartoService GyartoService
@inject IUgyfelService UgyfelService
@inject ITelephelyService TelephelyService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Eszközök</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Eszközök</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (név, gyári szám)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új eszköz</MudButton>
    </MudStack>

    <MudDataGrid T="Eszkoz" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="e => e.Nev" Title="Név" />
            <PropertyColumn Property="e => e.GyariSzam" Title="Gyári szám" />
            <PropertyColumn Property="e => e.Tipus" Title="Típus" />
            <TemplateColumn Title="Gyártó">
                <CellTemplate>@(context.Item.Gyarto?.Nev ?? "-")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Ügyfél">
                <CellTemplate>@(context.Item.Ugyfel?.Nev ?? "-")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Telephely">
                <CellTemplate>@(context.Item.Telephely?.Nev ?? "-")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető eszköz.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Eszköz szerkesztése" : "Új eszköz")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Nev" Label="Név *" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.GyariSzam" Label="Gyári szám" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Tipus" Label="Típus" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_szerkesztesAlatt.GyartoId" Label="Gyártó *">
                        @foreach (var g in _gyartok)
                        {
                            <MudSelectItem Value="@g.Id">@g.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_szerkesztesAlatt.UgyfelId" Label="Ügyfél *">
                        @foreach (var u in _ugyfelek)
                        {
                            <MudSelectItem Value="@u.Id">@u.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int?" @bind-Value="_szerkesztesAlatt.TelephelyId" Label="Telephely" Clearable="true">
                        @foreach (var t in _telephelyek)
                        {
                            <MudSelectItem Value="@((int?)t.Id)">@t.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Eszkoz> _lista = new();
    private List<Gyarto> _gyartok = new();
    private List<Ugyfel> _ugyfelek = new();
    private List<Telephely> _telephelyek = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private Eszkoz? _szerkesztesAlatt;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<Eszkoz> _szurtLista => string.IsNullOrWhiteSpace(_kereses) ? _lista
        : _lista.Where(e => (e.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (e.GyariSzam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await BetoltesAsync();
        _gyartok = await GyartoService.GetAllAsync();
        _ugyfelek = await UgyfelService.GetAllAsync();
        _telephelyek = await TelephelyService.GetAllAsync();
    }

    private async Task BetoltesAsync() { _betoltes = true; _lista = await EszkozService.GetAllAsync(); _betoltes = false; }

    private void UjMegnyitasa() { _szerkesztesAlatt = new Eszkoz { Aktiv = true }; _dialogNyitva = true; }
    private void SzerkesztesMegnyitasa(Eszkoz item) { _szerkesztesAlatt = new Eszkoz { Id = item.Id, Nev = item.Nev, GyariSzam = item.GyariSzam, Tipus = item.Tipus, GyartoId = item.GyartoId, UgyfelId = item.UgyfelId, TelephelyId = item.TelephelyId, Aktiv = item.Aktiv }; _dialogNyitva = true; }
    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev)) { Snackbar.Add("A név megadása kötelező!", Severity.Warning); return; }
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await EszkozService.CreateAsync(_szerkesztesAlatt);
            else await EszkozService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success); DialogBezarasa(); await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Eszkoz item)
    {
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli: \"{item.Nev}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await EszkozService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }
}