@page "/admin/kepzes-tipusok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IKepzesTipusService KepzesTipusService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Képzés típusok</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.School" Class="mr-2" />
    Képzés / Bizonyítvány típusok
</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Itt határozhatja meg a különböző bizonyítvány típusok szabályait: lejárat, továbbképzési kötelezettség, stb.
</MudAlert>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:300px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">
            Új típus
        </MudButton>
    </MudStack>

    <MudDataGrid T="KepzesTipus" Items="_szurtLista" Filterable="false" SortMode="SortMode.Single" Hover="true" Striped="true" Loading="_betoltes" Dense="true">
        <Columns>
            <PropertyColumn Property="k => k.Nev" Title="Megnevezés" />
            <TemplateColumn Title="Lejárat">
                <CellTemplate>
                    @if (context.Item.Lejar && context.Item.LejaratEvek.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.Item.LejaratEvek év</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Nem jár le</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Továbbképzés">
                <CellTemplate>
                    @if (context.Item.TovabbkepzesKotelezo && context.Item.TovabbkepzesEvek.HasValue)
                    {
                        <MudStack Spacing="0">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Item.TovabbkepzesEvek évente</MudChip>
                            @if (context.Item.TovabbkepzesCsakFelulvizsgalonak)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Csak felelős/ellenőr</MudText>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Color="Color.Default">Nem kötelező</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudSwitch T="bool" Value="@context.Item.Aktiv" ValueChanged="@(v => AktivValtas(context.Item, v))" Color="Color.Success" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető típus.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.School" Class="mr-2" />
            @(_szerkesztesAlatt?.Id > 0 ? "Típus szerkesztése" : "Új típus")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Nev" Label="Megnevezés *" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1" Class="mb-2">📅 Lejárat beállítások</MudText>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_szerkesztesAlatt.Lejar" Label="Bizonyítvány lejár" Color="Color.Warning" />
                </MudItem>
                <MudItem xs="12" md="6">
                    @if (_szerkesztesAlatt.Lejar)
                    {
                        <MudNumericField @bind-Value="_szerkesztesAlatt.LejaratEvek" Label="Hány év múlva jár le?" Min="1" Max="20" Variant="Variant.Outlined" />
                    }
                </MudItem>
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1" Class="mb-2">📚 Továbbképzés beállítások</MudText>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_szerkesztesAlatt.TovabbkepzesKotelezo" Label="Továbbképzés kötelező" Color="Color.Info" />
                </MudItem>
                <MudItem xs="12" md="6">
                    @if (_szerkesztesAlatt.TovabbkepzesKotelezo)
                    {
                        <MudNumericField @bind-Value="_szerkesztesAlatt.TovabbkepzesEvek" Label="Hány évente?" Min="1" Max="10" Variant="Variant.Outlined" />
                    }
                </MudItem>
                
                @if (_szerkesztesAlatt.TovabbkepzesKotelezo)
                {
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_szerkesztesAlatt.TovabbkepzesCsakFelulvizsgalonak" 
                                   Label="Csak felelős/ellenőr felülvizsgálónak kell (segítőnek nem)" Color="Color.Secondary" />
                    </MudItem>
                }
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Leiras" Label="Leírás / Megjegyzés" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Success" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<KepzesTipus> _lista = [];
    private string _kereses = "";
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private KepzesTipus? _szerkesztesAlatt;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<KepzesTipus> _szurtLista => string.IsNullOrWhiteSpace(_kereses) 
        ? _lista 
        : _lista.Where(k => k.Nev.Contains(_kereses, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _lista = await KepzesTipusService.GetAllAsync();
        _betoltes = false;
    }

    private void UjMegnyitasa()
    {
        _szerkesztesAlatt = new KepzesTipus { Aktiv = true };
        _dialogNyitva = true;
    }

    private void SzerkesztesMegnyitasa(KepzesTipus item)
    {
        _szerkesztesAlatt = new KepzesTipus
        {
            Id = item.Id,
            Nev = item.Nev,
            Lejar = item.Lejar,
            LejaratEvek = item.LejaratEvek,
            TovabbkepzesKotelezo = item.TovabbkepzesKotelezo,
            TovabbkepzesEvek = item.TovabbkepzesEvek,
            TovabbkepzesCsakFelulvizsgalonak = item.TovabbkepzesCsakFelulvizsgalonak,
            Leiras = item.Leiras,
            Aktiv = item.Aktiv
        };
        _dialogNyitva = true;
    }

    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev))
        {
            Snackbar.Add("A megnevezés kötelező!", Severity.Warning);
            return;
        }
        
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0)
                await KepzesTipusService.CreateAsync(_szerkesztesAlatt);
            else
                await KepzesTipusService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success);
            DialogBezarasa();
            _lista = await KepzesTipusService.GetAllAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task AktivValtas(KepzesTipus item, bool aktiv)
    {
        item.Aktiv = aktiv;
        await KepzesTipusService.UpdateAsync(item);
        Snackbar.Add(aktiv ? "Aktiválva!" : "Inaktiválva!", Severity.Info);
    }

    private async Task TorlesMegerosites(KepzesTipus item)
    {
        if (await DialogService.ShowMessageBox("Törlés", $"Biztosan törli: \"{item.Nev}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try
            {
                await KepzesTipusService.DeleteAsync(item.Id);
                Snackbar.Add("Törölve.", Severity.Success);
                _lista = await KepzesTipusService.GetAllAsync();
            }
            catch
            {
                Snackbar.Add("Nem törölhető - használatban van!", Severity.Error);
            }
        }
    }
}