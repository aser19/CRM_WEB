    private async Task ValidalasEsTovabblepesAsync()
    {
        try
        {
            if (_kivalasztottTipusId == 0)
            {
                Snackbar.Add("Válassz jegyzőkönyv típust!", Severity.Warning);
                return;
            }
            
            if (_kivalasztottUgyfelId == 0)
            {
                Snackbar.Add("Válassz ügyfelet!", Severity.Warning);
                return;
            }
            
            if (_kivalasztottTelephelyId == 0)
            {
                Snackbar.Add("Válassz telephelyet!", Severity.Warning);
                return;
            }
            
            // Ellenőrizzük a jogosultságot
            var (vanJogosult, hianyzoKepzesek) = await JogosultsagService
                .EllenorizJogosultsagotAsync(_kivalasztottTipusId);
            
            if (!vanJogosult)
            {
                var tipus = _tipusok.FirstOrDefault(t => t.Id == _kivalasztottTipusId);
                var tipusNev = tipus?.Nev ?? "a kiválasztott típus";
                
                var hibaUzenet = $"Nincs jogosult felelős felülvizsgáló a cégnél a(z) '{tipusNev}' jegyzőkönyvhöz!";
                
                if (hianyzoKepzesek.Count > 0)
                {
                    hibaUzenet += $" Hiányzó képzés(ek): {string.Join(", ", hianyzoKepzesek)}";
                }
                
                Snackbar.Add(hibaUzenet, Severity.Error, config =>
                {
                    config.ShowCloseIcon = true;
                    config.VisibleStateDuration = 10000;
                });
                return;
            }
            
            // Frissítjük a jogosult felülvizsgálók listáját
            _jogosultFelulvizsgalok = await JogosultsagService
                .GetJogosultFelulvizsgalokAsync(_kivalasztottTipusId);
            
            StateHasChanged();
            await _stepper.NextStepAsync();
        }
        catch (Exception ex)
        {
            // Felhasználóbarát hibaüzenet
            Snackbar.Add("Hiba történt a jogosultság ellenőrzésekor. Kérjük, próbáld újra később.", Severity.Error);
            
            // Fejlesztői konzolra a részletes hiba
            Console.WriteLine($"[ValidalasEsTovabblepesAsync] {ex}");
        }
    }

    private void OnEredmenyValtozas(String ujErtek)
    {
        _adatok.Eredmeny = ujErtek;
        
        // Automatikusan frissítjük a végső minősítést is
        _adatok.VegsoMinosites = ujErtek;
    }

    private bool VanKitoltottHiba() =>
        !string.IsNullOrWhiteSpace(_adatok.HibakB) ||
        !string.IsNullOrWhiteSpace(_adatok.HibakC) ||
        !string.IsNullOrWhiteSpace(_adatok.HibakD) ||
        !string.IsNullOrWhiteSpace(_adatok.HibakE);

    private string GetHibakOsszegzes()
    {
        var hibak = new List<string>();
        if (!string.IsNullOrWhiteSpace(_adatok.HibakB)) hibak.Add("B");
        if (!string.IsNullOrWhiteSpace(_adatok.HibakC)) hibak.Add("C");
        if (!string.IsNullOrWhiteSpace(_adatok.HibakD)) hibak.Add("D");
        if (!string.IsNullOrWhiteSpace(_adatok.HibakE)) hibak.Add("E");
        return hibak.Count > 0 ? $"Kitöltött pontok: {string.Join(", ", hibak)}" : "Nincs";
    }

    // Ellenőr keresési függvény
    private Task<IEnumerable<string>> EllenorKereses(string kereses, CancellationToken token)
    {
        var nevLista = _osszFelulvizsgalo.Select(f => f.Nev).ToList();
        
        if (string.IsNullOrWhiteSpace(kereses))
            return Task.FromResult(nevLista.AsEnumerable());
        
        var szurt = nevLista
            .Where(n => n.Contains(kereses, StringComparison.OrdinalIgnoreCase));
        
        return Task.FromResult(szurt);
    }
