@page "/jegyzokonyv/{MeresId:int?}"
@page "/jegyzokonyv/uj"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@using BiztvillCRM.Services
@inject IMeresService MeresService
@inject IUgyfelService UgyfelService
@inject ITelephelyService TelephelyService
@inject IMeresTipusService MeresTipusService
@inject IJegyzokonyvWordService JegyzokonyvWordService
@inject IJegyzokonyvJogosultsagService JogosultsagService
@inject IFelulvizsgaloService FelulvizsgaloService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ITenantService TenantService
@inject ICegService CegService

<PageTitle>Jegyzőkönyv szerkesztő</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
    Jegyzőkönyv szerkesztő
</MudText>

<MudStepper @ref="_stepper" Linear="false" Color="Color.Primary">
    
    @* === 1. LÉPÉS: KIVÁLASZTÁS === *@
    <MudStep Title="Kiválasztás" Icon="@Icons.Material.Filled.ListAlt">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Jegyzőkönyv típusa és ügyfél</MudText>
            
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Value="_kivalasztottTipusId" Label="Jegyzőkönyv típusa *" 
                               ValueChanged="OnTipusValtozas"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var tipus in _tipusok)
                        {
                            <MudSelectItem Value="@tipus.Id">@tipus.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Value="_kivalasztottUgyfelId" Label="Ügyfél *"
                               ValueChanged="OnUgyfelValtozas" Variant="Variant.Outlined">
                        @foreach (var ugyfel in _ugyfelek)
                        {
                            <MudSelectItem Value="@ugyfel.Id">@ugyfel.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_kivalasztottTelephelyId" Label="Telephely *"
                               Variant="Variant.Outlined" Disabled="@(_szurtTelephelyek.Count == 0)">
                        @foreach (var telephely in _szurtTelephelyek)
                        {
                            <MudSelectItem Value="@telephely.Id">@telephely.Nev - @telephely.Cim</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_vizsgalatDatum" Label="Vizsgálat dátuma *" 
                                   Variant="Variant.Outlined" DateFormat="yyyy.MM.dd" />
                </MudItem>
                
                @* === VALIDÁCIÓS GOMB === *@
                <MudItem xs="12" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                               OnClick="ValidalasEsTovabblepesAsync"
                               EndIcon="@Icons.Material.Filled.ArrowForward">
                        Tovább az adatok megadásához
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudStep>
    
    @* === 2. LÉPÉS: ADATOK KITÖLTÉSE === *@
    <MudStep Title="Adatok megadása" Icon="@Icons.Material.Filled.Edit">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Vizsgálat adatai</MudText>
            
            <MudGrid>
                @* Automatikusan kitöltött mezők *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.JegyzokonyvSzam" Label="Jegyzőkönyv száma" 
                                  Variant="Variant.Outlined" ReadOnly="true" 
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Lock" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.CegNev" Label="Vizsgáló cég neve" 
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Lock" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.CegCim" Label="Vizsgáló cég címe" 
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Lock" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.VizsgalatHelye" Label="Vizsgálat helye" 
                                  Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.VizsgalatTargya" Label="Vizsgálat tárgya" 
                                  Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.VizsgaltBerendezes" Label="Vizsgált berendezés" 
                                  Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.Megrendelo" Label="Megrendelő neve" 
                                  Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.VizsgalatIdotartama" Label="Vizsgálat időtartama" 
                                  Variant="Variant.Outlined" Placeholder="pl. 2 óra" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_adatok.Megjegyzes" Label="Megjegyzések" 
                                  Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                
                @* Eredmény *@
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Vizsgálat eredménye</MudText>
                    <MudToggleGroup T="string" @bind-Value="_adatok.Eredmeny" Color="Color.Primary" 
                                    Rounded="true" CheckMark="true">
                        <MudToggleItem Value="@("MEGFELELT")" Text="Megfelelt" />
                        <MudToggleItem Value="@("NEM FELELT MEG")" Text="Nem felelt meg" />
                    </MudToggleGroup>
                </MudItem>
                
                @* === MEGRENDELŐ KÉPVISELŐI === *@
                <MudItem xs="12"><MudDivider Class="my-3" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.UzemiKisero" Label="Üzemi kísérő" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_adatok.KapcsolatTarto" Label="Kapcsolattartó" Variant="Variant.Outlined" />
                </MudItem>

                @* === FELÜLVIZSGÁLÓK (ÚJ STRUKTÚRA) === *@
                <MudItem xs="12">
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Felülvizsgálók</MudText>
                    @if (_jogosultFelulvizsgalok.Count == 0 && _kivalasztottTipusId > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-2">
                            Nincs jogosult felülvizsgáló ehhez a jegyzőkönyv típushoz!
                        </MudAlert>
                    }
                </MudItem>

                @* === FELELŐS FELÜLVIZSGÁLÓ === *@
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Felelős felülvizsgáló *"
                               Value="_kivalasztottFelulvizsgaloId"
                               ValueChanged="OnFelulvizsgaloValtozasAsync"
                               Variant="Variant.Outlined">
                        <MudSelectItem T="int?" Value="null">-- Válassz --</MudSelectItem>
                        @foreach (var szemely in _jogosultFelulvizsgalok.Where(f => f.LehetFelelosFelulvizsgalo))
                        {
                            <MudSelectItem T="int?" Value="@szemely.Id">
                                @szemely.Nev (@szemely.Jogosultsag)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_adatok.FelulvizsgaloBizonyitvany" Label="Bizonyítvány(ok)" 
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_adatok.FelulvizsgaloKepzes" Label="Továbbképzés(ek)" 
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>

                @* === SEGÍTŐ === *@
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Segítő-felülvizsgáló"
                               Value="_kivalasztottSegitoId"
                               ValueChanged="OnSegitoValtozasAsync"
                               Variant="Variant.Outlined">
                        <MudSelectItem T="int?" Value="null">-- Válassz --</MudSelectItem>
                        @foreach (var szemely in _jogosultFelulvizsgalok)
                        {
                            <MudSelectItem T="int?" Value="@szemely.Id">@szemely.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_adatok.SegitoBizonyitvany" Label="Bizonyítvány(ok)" 
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_adatok.SegitoKepzes" Label="Továbbképzés(ek)" 
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>

                @* === ELLENŐR (bárki lehet) === *@
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Ellenőrizte"
                               Value="_kivalasztottEllenorId"
                               ValueChanged="OnEllenorValtozasAsync"
                               Variant="Variant.Outlined">
                        <MudSelectItem T="int?" Value="null">-- Válassz --</MudSelectItem>
                        @foreach (var szemely in _osszFelulvizsgalo)
                        {
                            <MudSelectItem T="int?" Value="@szemely.Id">@szemely.Nev</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        <em>Tartalmi és formai ellenőrzés - nem szükséges képzés</em>
                    </MudAlert>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudStep>
    
    @* === 3. LÉPÉS: ELŐNÉZET ÉS LETÖLTÉS === *@
    <MudStep Title="Letöltés" Icon="@Icons.Material.Filled.Download">
        <MudPaper Class="pa-4">
            <MudSimpleTable Dense="true" Bordered="true" Class="mb-4">
                <tbody>
                    <tr><td><strong>Jegyzőkönyv száma</strong></td><td>@_adatok.JegyzokonyvSzam</td></tr>
                    <tr><td><strong>Ügyfél</strong></td><td>@_adatok.Megrendelo</td></tr>
                    <tr><td><strong>Helyszín</strong></td><td>@_adatok.VizsgalatHelye</td></tr>
                    <tr><td><strong>Felelős felülvizsgáló</strong></td><td>@_adatok.FelulvizsgaloNev</td></tr>
                    <tr><td><strong>Bizonyítványok</strong></td><td>@_adatok.FelulvizsgaloBizonyitvany</td></tr>
                    <tr><td><strong>Eredmény</strong></td>
                        <td><MudChip T="string" Color="@(_adatok.Eredmeny == "MEGFELELT" ? Color.Success : Color.Error)" Size="Size.Small">@_adatok.Eredmeny</MudChip></td>
                    </tr>
                </tbody>
            </MudSimpleTable>
            
            <MudStack Row="true" Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Download" OnClick="LetoltesAsync"
                           Disabled="_feldolgozas">
                    @(_feldolgozas ? "Generálás..." : "Letöltés (Word)")
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudStep>
</MudStepper>

@code {
    [Parameter] public int? MeresId { get; set; }
    
    private MudStepper _stepper = null!;
    private List<MeresTipus> _tipusok = [];
    private List<Ugyfel> _ugyfelek = [];
    private List<Telephely> _telephelyek = [];
    private List<Telephely> _szurtTelephelyek = [];
    
    private int _kivalasztottTipusId;
    private int _kivalasztottUgyfelId;
    private int _kivalasztottTelephelyId;
    private DateTime? _vizsgalatDatum = DateTime.Today;
    private bool _feldolgozas;
    
    private JegyzokonyvFormAdatok _adatok = new();

    // === FELÜLVIZSGÁLÓK (ÚJ STRUKTÚRA) ===
    private List<Felulvizsgalo> _osszFelulvizsgalo = [];
    private List<Felulvizsgalo> _jogosultFelulvizsgalok = [];
    
    private int? _kivalasztottFelulvizsgaloId;
    private int? _kivalasztottSegitoId;
    private int? _kivalasztottEllenorId;

    protected override async Task OnInitializedAsync()
    {
        _tipusok = await MeresTipusService.GetAllAsync();
        _ugyfelek = await UgyfelService.GetAllAsync();
        _telephelyek = await TelephelyService.GetAllAsync();
        _osszFelulvizsgalo = await FelulvizsgaloService.GetAllAsync();
        
        await BetoltCegAdatokAsync();
        
        if (MeresId.HasValue)
            await BetoltMeresbolAsync(MeresId.Value);
        else
            GeneralJegyzokonyvSzam();
    }

    private async Task OnTipusValtozas(int tipusId)
    {
        _kivalasztottTipusId = tipusId;
        
        // Frissítjük a jogosult felülvizsgálók listáját
        if (tipusId > 0)
        {
            _jogosultFelulvizsgalok = await JogosultsagService.GetJogosultFelulvizsgalokAsync(tipusId);
        }
        else
        {
            _jogosultFelulvizsgalok = _osszFelulvizsgalo;
        }
        
        // Jegyzőkönyv szám prefix frissítése
        var tipus = _tipusok.FirstOrDefault(t => t.Id == tipusId);
        if (tipus != null)
        {
            var prefix = tipus.JegyzokonyvPrefix ?? "JKV";
            var sorszam = MeresId ?? new Random().Next(1, 9999);
            _adatok.JegyzokonyvSzam = $"{prefix}-{sorszam:D6}/{DateTime.Now:yyyy}";
        }
        
        // Reset felülvizsgáló kiválasztás
        _kivalasztottFelulvizsgaloId = null;
        _kivalasztottSegitoId = null;
        _adatok.FelulvizsgaloNev = "";
        _adatok.FelulvizsgaloBizonyitvany = "";
        _adatok.FelulvizsgaloKepzes = "";
    }

    private async Task OnFelulvizsgaloValtozasAsync(int? id)
    {
        _kivalasztottFelulvizsgaloId = id;
        if (id.HasValue && _kivalasztottTipusId > 0)
        {
            var felulvizsgalo = _jogosultFelulvizsgalok.FirstOrDefault(f => f.Id == id);
            _adatok.FelulvizsgaloNev = felulvizsgalo?.Nev ?? "";
            
            // Dinamikus bizonyítvány és továbbképzés szöveg
            _adatok.FelulvizsgaloBizonyitvany = await JogosultsagService.GeneralBizonyitvanySzovegetAsync(_kivalasztottTipusId, id.Value);
            _adatok.FelulvizsgaloKepzes = await JogosultsagService.GeneralTovabbkepzesSzovegetAsync(_kivalasztottTipusId, id.Value);
        }
        else
        {
            _adatok.FelulvizsgaloNev = "";
            _adatok.FelulvizsgaloBizonyitvany = "";
            _adatok.FelulvizsgaloKepzes = "";
        }
    }

    private async Task OnSegitoValtozasAsync(int? id)
    {
        _kivalasztottSegitoId = id;
        if (id.HasValue && _kivalasztottTipusId > 0)
        {
            var felulvizsgalo = _jogosultFelulvizsgalok.FirstOrDefault(f => f.Id == id);
            _adatok.SegitoFelulvizsgalo = felulvizsgalo?.Nev ?? "";
            _adatok.SegitoBizonyitvany = await JogosultsagService.GeneralBizonyitvanySzovegetAsync(_kivalasztottTipusId, id.Value);
            _adatok.SegitoKepzes = await JogosultsagService.GeneralTovabbkepzesSzovegetAsync(_kivalasztottTipusId, id.Value);
        }
        else
        {
            _adatok.SegitoFelulvizsgalo = "";
            _adatok.SegitoBizonyitvany = "";
            _adatok.SegitoKepzes = "";
        }
    }

    private async Task OnEllenorValtozasAsync(int? id)
    {
        _kivalasztottEllenorId = id;
        var felulvizsgalo = _osszFelulvizsgalo.FirstOrDefault(f => f.Id == id);
        _adatok.Ellenor = felulvizsgalo?.Nev ?? "";
        // Ellenőrnél nem kell képzési adat
    }

    private void OnUgyfelValtozas(int ugyfelId)
    {
        _kivalasztottUgyfelId = ugyfelId;
        _szurtTelephelyek = _telephelyek.Where(t => t.UgyfelId == ugyfelId).ToList();
        _kivalasztottTelephelyId = _szurtTelephelyek.FirstOrDefault()?.Id ?? 0;
        
        var ugyfel = _ugyfelek.FirstOrDefault(u => u.Id == ugyfelId);
        var telephely = _szurtTelephelyek.FirstOrDefault();
        
        _adatok.Megrendelo = ugyfel?.Nev ?? "";
        _adatok.VizsgalatHelye = telephely?.Cim ?? "";
        _adatok.KapcsolatTarto = telephely?.Kapcsolattarto ?? "";
    }

    private async Task BetoltCegAdatokAsync()
    {
        var cegId = TenantService.GetCurrentCegId();
        var ceg = await CegService.GetByIdAsync(cegId);
        if (ceg != null)
        {
            _adatok.CegNev = ceg.Nev;
            _adatok.CegCim = ceg.Cim ?? "";
        }
    }

    private async Task BetoltMeresbolAsync(int meresId)
    {
        var meres = await MeresService.GetByIdAsync(meresId);
        if (meres != null)
        {
            await OnTipusValtozas(meres.MeresTipusId);
            OnUgyfelValtozas(meres.UgyfelId);
            _kivalasztottTelephelyId = meres.TelephelyId;
            _vizsgalatDatum = meres.Datum;
            _adatok.VizsgalatHelye = meres.Telephely?.Cim ?? "";
            _adatok.Megrendelo = meres.Ugyfel?.Nev ?? "";
            _adatok.Eredmeny = meres.Eredmeny ?? "";
            _adatok.Megjegyzes = meres.Megjegyzes ?? "";
        }
    }

    private void GeneralJegyzokonyvSzam()
    {
        var sorszam = MeresId ?? new Random().Next(1, 9999);
        _adatok.JegyzokonyvSzam = $"JKV-{sorszam:D6}/{DateTime.Now:yyyy}";
    }

    private async Task LetoltesAsync()
    {
        if (!Validacio()) return;
        
        _feldolgozas = true;
        try
        {
            var meresId = await MentesVagyFrissitesAsync();
            
            var jegyzokonyvAdatok = new JegyzokonyvAdatok
            {
                JegyzokonyvSzam = _adatok.JegyzokonyvSzam,
                CegNev = _adatok.CegNev,
                CegCim = _adatok.CegCim,
                VizsgalatHelye = _adatok.VizsgalatHelye,
                VizsgalatTargya = _adatok.VizsgalatTargya,
                VizsgaltBerendezes = _adatok.VizsgaltBerendezes,
                Megrendelo = _adatok.Megrendelo,
                VizsgalatIdotartama = _adatok.VizsgalatIdotartama,
                Eredmeny = _adatok.Eredmeny,
                Megjegyzes = _adatok.Megjegyzes,
                UzemiKisero = _adatok.UzemiKisero,
                KapcsolatTarto = _adatok.KapcsolatTarto,
                FelulvizsgaloNev = _adatok.FelulvizsgaloNev,
                FelulvizsgaloBizonyitvany = _adatok.FelulvizsgaloBizonyitvany,
                FelulvizsgaloKepzes = _adatok.FelulvizsgaloKepzes,
                SegitoFelulvizsgalo = _adatok.SegitoFelulvizsgalo,
                SegitoBizonyitvany = _adatok.SegitoBizonyitvany,
                SegitoKepzes = _adatok.SegitoKepzes,
                Ellenor = _adatok.Ellenor
            };
            
            var wordBytes = await JegyzokonyvWordService.GeneralasAsync(meresId, jegyzokonyvAdatok);
            var fileName = $"{_adatok.JegyzokonyvSzam.Replace("/", "_")}.docx";
            
            using var streamRef = new DotNetStreamReference(new MemoryStream(wordBytes));
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            
            Snackbar.Add("Jegyzőkönyv letöltve!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
        finally
        {
            _feldolgozas = false;
        }
    }

    private async Task<int> MentesVagyFrissitesAsync()
    {
        if (MeresId.HasValue) return MeresId.Value;
            
        var ujMeres = new Meres
        {
            UgyfelId = _kivalasztottUgyfelId,
            TelephelyId = _kivalasztottTelephelyId,
            MeresTipusId = _kivalasztottTipusId,
            Datum = _vizsgalatDatum ?? DateTime.Today,
            Eredmeny = _adatok.Eredmeny,
            Megjegyzes = _adatok.Megjegyzes
        };
        
        var mentett = await MeresService.CreateAsync(ujMeres);
        return mentett.Id;
    }

    private bool Validacio()
    {
        if (_kivalasztottTipusId == 0) { Snackbar.Add("Válassz típust!", Severity.Warning); return false; }
        if (_kivalasztottUgyfelId == 0) { Snackbar.Add("Válassz ügyfelet!", Severity.Warning); return false; }
        if (_kivalasztottFelulvizsgaloId == null) { Snackbar.Add("Válassz felelős felülvizsgálót!", Severity.Warning); return false; }
        return true;
    }

    private class JegyzokonyvFormAdatok
    {
        public string JegyzokonyvSzam { get; set; } = "";
        public string CegNev { get; set; } = "";
        public string CegCim { get; set; } = "";
        public string VizsgalatHelye { get; set; } = "";
        public string VizsgalatTargya { get; set; } = "";
        public string VizsgaltBerendezes { get; set; } = "";
        public string Megrendelo { get; set; } = "";
        public string VizsgalatIdotartama { get; set; } = "";
        public string Eredmeny { get; set; } = "MEGFELELT";
        public string Megjegyzes { get; set; } = "";
        public string UzemiKisero { get; set; } = "";
        public string KapcsolatTarto { get; set; } = "";
        public string FelulvizsgaloNev { get; set; } = "";
        public string FelulvizsgaloBizonyitvany { get; set; } = "";
        public string FelulvizsgaloKepzes { get; set; } = "";
        public string SegitoFelulvizsgalo { get; set; } = "";
        public string SegitoBizonyitvany { get; set; } = "";
        public string SegitoKepzes { get; set; } = "";
        public string Ellenor { get; set; } = "";
    }

    private async Task ValidalasEsTovabblepesAsync()
    {
        if (_kivalasztottTipusId == 0)
        {
            Snackbar.Add("Válassz jegyzőkönyv típust!", Severity.Warning);
            return;
        }
        
        if (_kivalasztottUgyfelId == 0)
        {
            Snackbar.Add("Válassz ügyfelet!", Severity.Warning);
            return;
        }
        
        if (_kivalasztottTelephelyId == 0)
        {
            Snackbar.Add("Válassz telephelyet!", Severity.Warning);
            return;
        }
        
        // Ellenőrizzük a jogosultságot
        var (vanJogosult, hianyzoKepzesek) = await JogosultsagService.EllenorizJogosultsagotAsync(_kivalasztottTipusId);
        
        if (!vanJogosult)
        {
            var tipus = _tipusok.FirstOrDefault(t => t.Id == _kivalasztottTipusId);
            var tipusNev = tipus?.Nev ?? "a kiválasztott típus";
            
            var hibaUzenet = $"Nincs jogosult felelős felülvizsgáló a cégnél a(z) '{tipusNev}' jegyzőkönyvhöz!";
            
            if (hianyzoKepzesek.Count > 0)
            {
                hibaUzenet += $" Hiányzó képzés(ek): {string.Join(", ", hianyzoKepzesek)}";
            }
            
            Snackbar.Add(hibaUzenet, Severity.Error, config =>
            {
                config.ShowCloseIcon = true;
                config.VisibleStateDuration = 10000;
            });
            return;
        }
        
        // Frissítjük a jogosult felülvizsgálók listáját
        _jogosultFelulvizsgalok = await JogosultsagService.GetJogosultFelulvizsgalokAsync(_kivalasztottTipusId);
        
        // Lépés a következő step-re - JAVÍTOTT
        await _stepper.NextStepAsync();
    }
}