@page "/terminalok"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Services.Interfaces
@inject ITerminalService TerminalService
@inject ITelephelyService TelephelyService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Terminálok</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Terminálok</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés (név, azonosító, IP)" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">Új terminál</MudButton>
    </MudStack>

    <MudDataGrid T="Terminal" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="t => t.Nev" Title="Név" />
            <PropertyColumn Property="t => t.Azonosito" Title="Azonosító" />
            <PropertyColumn Property="t => t.IpCim" Title="IP cím" />
            <TemplateColumn Title="Telephely">
                <CellTemplate>@(context.Item.Telephely?.Nev ?? "-")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető terminál.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">@(_szerkesztesAlatt?.Id > 0 ? "Terminál szerkesztése" : "Új terminál")</MudText></TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Nev" Label="Név *" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.Azonosito" Label="Azonosító" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_szerkesztesAlatt.IpCim" Label="IP cím" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int?" @bind-Value="_szerkesztesAlatt.TelephelyId" Label="Telephely" Clearable="true">
                        @foreach (var t in _telephelyek) { <MudSelectItem Value="@((int?)t.Id)">@t.Nev</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_szerkesztesAlatt.Megjegyzes" Label="Megjegyzés" Lines="2" /></MudItem>
                <MudItem xs="12"><MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Terminal> _lista = new();
    private List<Telephely> _telephelyek = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private Terminal? _szerkesztesAlatt;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private IEnumerable<Terminal> _szurtLista => string.IsNullOrWhiteSpace(_kereses) ? _lista
        : _lista.Where(t => (t.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (t.Azonosito?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (t.IpCim?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _telephelyek = await TelephelyService.GetAllAsync();
            await BetoltesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba a betöltés során: {ex.Message}", Severity.Error);
            _betoltes = false;
        }
    }

    private async Task BetoltesAsync()
    {
        _betoltes = true;
        try
        {
            _lista = await TerminalService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
        finally
        {
            _betoltes = false;
        }
    }

    private void UjMegnyitasa() { _szerkesztesAlatt = new Terminal { Aktiv = true }; _dialogNyitva = true; }
    private void SzerkesztesMegnyitasa(Terminal item) { _szerkesztesAlatt = new Terminal { Id = item.Id, Nev = item.Nev, Azonosito = item.Azonosito, IpCim = item.IpCim, TelephelyId = item.TelephelyId, Megjegyzes = item.Megjegyzes, Aktiv = item.Aktiv }; _dialogNyitva = true; }
    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev)) { Snackbar.Add("A név megadása kötelező!", Severity.Warning); return; }
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0) await TerminalService.CreateAsync(_szerkesztesAlatt);
            else await TerminalService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success); DialogBezarasa(); await BetoltesAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task TorlesMegerosites(Terminal item)
    {
        if (await DialogService.ShowMessageBox("Törlés megerősítése", $"Biztosan törli: \"{item.Nev}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            try { await TerminalService.DeleteAsync(item.Id); Snackbar.Add("Törölve.", Severity.Success); await BetoltesAsync(); }
            catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        }
    }
}
