@page "/kepzesek"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Shared.Enums
@using BiztvillCRM.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IKepzesService KepzesService
@inject IKepzesTipusService KepzesTipusService
@inject ICegService CegService
@inject ITenantService TenantService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Felülvizsgálók</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2" />
    Felülvizsgálók
</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    <strong>Jogosultsági szintek:</strong><br/>
    🔹 <strong>Segítő</strong> - Csak segítő felülvizsgálóként dolgozhat<br/>
    🔸 <strong>Felelős</strong> - Felelős felülvizsgáló és segítő is lehet<br/>
    🔶 <strong>Ellenőr</strong> - Ellenőr, felelős felülvizsgáló és segítő is lehet
    @if (!_isAdmin)
    {
        <br/><br/>
        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
        <em>Felülvizsgálók hozzáadásához és módosításához admin jogosultság szükséges.</em>
    }
</MudAlert>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses" Label="Keresés" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="max-width:300px;" />
        @if (_isAdmin)
        {
            <MudSelect T="int" @bind-Value="_szuroCegId" Label="Cég szűrő" Style="min-width: 200px;">
                <MudSelectItem Value="0">-- Összes cég --</MudSelectItem>
                @foreach (var ceg in _cegek)
                {
                    <MudSelectItem Value="@ceg.Id">@ceg.Nev</MudSelectItem>
                }
            </MudSelect>
        }
        <MudSpacer />
        @if (_isAdmin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="UjMegnyitasa">
                Új felülvizsgáló
            </MudButton>
        }
    </MudStack>

    <MudDataGrid T="Kepzes" Items="_szurtLista" Filterable="false" SortMode="SortMode.Multiple" Hover="true" Striped="true" Loading="_betoltes" Dense="true">
        <Columns>
            <PropertyColumn Property="k => k.Nev" Title="Név" />
            @if (_isAdmin)
            {
                <TemplateColumn Title="Cég">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Item.Ceg?.Nev</MudChip>
                    </CellTemplate>
                </TemplateColumn>
            }
            <TemplateColumn Title="Képzés típus">
                <CellTemplate>
                    @if (context.Item.KepzesTipus is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Tertiary">@context.Item.KepzesTipus.Nev</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Default">-</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="k => k.BizonyitvanySzam" Title="Bizonyítvány sz." />
            <TemplateColumn Title="Biz. kelte">
                <CellTemplate>
                    @if (context.Item.BizonyitvanyKelte.HasValue)
                    {
                        <MudText>@context.Item.BizonyitvanyKelte?.ToString("yyyy.MM.dd")</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Jogosultság">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" 
                             Color="@(context.Item.Jogosultsag == FelulvizsgaloJogosultsag.Ellenor ? Color.Primary : 
                                      context.Item.Jogosultsag == FelulvizsgaloJogosultsag.Felelos ? Color.Secondary : Color.Default)">
                        @JogosultsagNev(context.Item.Jogosultsag)
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    @if (_isAdmin)
                    {
                        <MudSwitch T="bool" Value="@context.Item.Aktiv" ValueChanged="@(v => AktivValtas(context.Item, v))" Color="Color.Success" />
                    }
                    else
                    {
                        <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" 
                                 Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                    }
                </CellTemplate>
            </TemplateColumn>
            @if (_isAdmin)
            {
                <TemplateColumn Title="Műveletek" Sortable="false">
                    <CellTemplate>
                        <MudStack Row="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => SzerkesztesMegnyitasa(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => TorlesMegerosites(context.Item)" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>
        <NoRecordsContent><MudText>Nincs megjeleníthető felülvizsgáló.</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

@if (_isAdmin)
{
    <MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2" />
                @(_szerkesztesAlatt?.Id > 0 ? "Felülvizsgáló szerkesztése" : "Új felülvizsgáló")
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (_szerkesztesAlatt is not null)
            {
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect T="int" @bind-Value="_kivalasztottCegId" Label="Cég *" Required="true" Variant="Variant.Outlined">
                            @foreach (var ceg in _cegek)
                            {
                                <MudSelectItem Value="@ceg.Id">@ceg.Nev</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="int?" @bind-Value="_kivalasztottKepzesTipusId" Label="Képzés típus *" Required="true" Variant="Variant.Outlined">
                            <MudSelectItem T="int?" Value="null">-- Válasszon típust --</MudSelectItem>
                            @foreach (var tipus in _kepzesTipusok)
                            {
                                <MudSelectItem T="int?" Value="@tipus.Id">@tipus.Nev</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    @if (_kivalasztottTipus is not null)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                                <strong>@_kivalasztottTipus.Nev szabályai:</strong>
                                @if (_kivalasztottTipus.Lejar && _kivalasztottTipus.LejaratEvek.HasValue)
                                {
                                    <span> | 📅 Lejár: @_kivalasztottTipus.LejaratEvek év</span>
                                }
                                else
                                {
                                    <span> | ✅ Nem jár le</span>
                                }
                                @if (_kivalasztottTipus.TovabbkepzesKotelezo && _kivalasztottTipus.TovabbkepzesEvek.HasValue)
                                {
                                    <span> | 📚 Továbbképzés: @_kivalasztottTipus.TovabbkepzesEvek évente</span>
                                    @if (_kivalasztottTipus.TovabbkepzesCsakFelulvizsgalonak)
                                    {
                                        <span> (csak felelős/ellenőr)</span>
                                    }
                                }
                            </MudAlert>
                        </MudItem>
                    }
                    
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_szerkesztesAlatt.Nev" Label="Felülvizsgáló neve *" Required="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_szerkesztesAlatt.BizonyitvanySzam" Label="Vizsgabizonyítvány száma" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="_bizonyitvanyKelte" Label="Bizonyítvány kelte" Variant="Variant.Outlined" DateFormat="yyyy.MM.dd" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect T="FelulvizsgaloJogosultsag" @bind-Value="_szerkesztesAlatt.Jogosultsag" Label="Jogosultsági szint *" Variant="Variant.Outlined">
                            <MudSelectItem Value="FelulvizsgaloJogosultsag.Segito">🔹 Segítő - Csak segítő felülvizsgálóként dolgozhat</MudSelectItem>
                            <MudSelectItem Value="FelulvizsgaloJogosultsag.Felelos">🔸 Felelős - Felelős felülvizsgáló és segítő is lehet</MudSelectItem>
                            <MudSelectItem Value="FelulvizsgaloJogosultsag.Ellenor">🔶 Ellenőr - Ellenőr, felelős és segítő is lehet</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_szerkesztesAlatt.Megjegyzes" Label="Megjegyzés" Lines="2" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Success" />
                    </MudItem>
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="DialogBezarasa">Mégse</MudButton>
            <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">@(_mentes ? "Mentés..." : "Mentés")</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<Kepzes> _lista = [];
    private List<Ceg> _cegek = [];
    private List<KepzesTipus> _kepzesTipusok = [];
    private string _kereses = "";
    private int _szuroCegId = 0;
    private bool _betoltes = true, _dialogNyitva = false, _mentes = false;
    private bool _isAdmin;
    private Kepzes? _szerkesztesAlatt;
    private DateTime? _bizonyitvanyKelte;
    private int _kivalasztottCegId;
    private int? _kivalasztottKepzesTipusId;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private KepzesTipus? _kivalasztottTipus => _kepzesTipusok.FirstOrDefault(t => t.Id == _kivalasztottKepzesTipusId);

    private IEnumerable<Kepzes> _szurtLista
    {
        get
        {
            var eredmeny = _lista.AsEnumerable();
            if (_isAdmin && _szuroCegId > 0)
                eredmeny = eredmeny.Where(k => k.CegId == _szuroCegId);
            if (!string.IsNullOrWhiteSpace(_kereses))
                eredmeny = eredmeny.Where(k => k.Nev.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ||
                                               (k.BizonyitvanySzam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                               (k.KepzesTipus?.Nev.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));
            return eredmeny;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = TenantService.IsInRole(FelhasznaloSzerepkor.Admin);
        _kepzesTipusok = await KepzesTipusService.GetAllActiveAsync();
        
        if (_isAdmin)
        {
            _cegek = await CegService.GetAllAsync();
            _lista = await KepzesService.GetAllAdminAsync();
        }
        else
        {
            _lista = await KepzesService.GetAllAsync();
        }
        
        _betoltes = false;
    }

    private string JogosultsagNev(FelulvizsgaloJogosultsag j) => j switch
    {
        FelulvizsgaloJogosultsag.Segito => "Segítő",
        FelulvizsgaloJogosultsag.Felelos => "Felelős",
        FelulvizsgaloJogosultsag.Ellenor => "Ellenőr",
        _ => "?"
    };

    private void UjMegnyitasa()
    {
        if (!_isAdmin) return;
        var cegId = _cegek.FirstOrDefault()?.Id ?? 0;
        _szerkesztesAlatt = new Kepzes { CegId = cegId, Aktiv = true, Jogosultsag = FelulvizsgaloJogosultsag.Segito };
        _kivalasztottCegId = cegId;
        _kivalasztottKepzesTipusId = null;
        _bizonyitvanyKelte = null;
        _dialogNyitva = true;
    }

    private void SzerkesztesMegnyitasa(Kepzes item)
    {
        if (!_isAdmin) return;
        _szerkesztesAlatt = new Kepzes
        {
            Id = item.Id,
            Nev = item.Nev,
            KepzesTipusId = item.KepzesTipusId,
            BizonyitvanySzam = item.BizonyitvanySzam,
            Jogosultsag = item.Jogosultsag,
            Megjegyzes = item.Megjegyzes,
            Aktiv = item.Aktiv,
            CegId = item.CegId
        };
        _kivalasztottCegId = item.CegId;
        _kivalasztottKepzesTipusId = item.KepzesTipusId;
        _bizonyitvanyKelte = item.BizonyitvanyKelte;
        _dialogNyitva = true;
    }

    private void DialogBezarasa() { _dialogNyitva = false; _szerkesztesAlatt = null; }

    private async Task MentesAsync()
    {
        if (!_isAdmin || _szerkesztesAlatt is null || string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev))
        {
            Snackbar.Add("A név megadása kötelező!", Severity.Warning);
            return;
        }
        
        _szerkesztesAlatt.BizonyitvanyKelte = _bizonyitvanyKelte;
        _szerkesztesAlatt.CegId = _kivalasztottCegId;
        _szerkesztesAlatt.KepzesTipusId = _kivalasztottKepzesTipusId;
        
        _mentes = true;
        try
        {
            if (_szerkesztesAlatt.Id == 0)
                await KepzesService.CreateAsync(_szerkesztesAlatt);
            else
                await KepzesService.UpdateAsync(_szerkesztesAlatt);
            Snackbar.Add("Sikeres mentés!", Severity.Success);
            DialogBezarasa();
            _lista = await KepzesService.GetAllAdminAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Hiba: {ex.Message}", Severity.Error); }
        finally { _mentes = false; }
    }

    private async Task AktivValtas(Kepzes item, bool aktiv)
    {
        if (!_isAdmin) return;
        item.Aktiv = aktiv;
        await KepzesService.UpdateAsync(item);
        Snackbar.Add(aktiv ? "Aktiválva!" : "Inaktiválva!", Severity.Info);
    }

    private async Task TorlesMegerosites(Kepzes item)
    {
        if (!_isAdmin) return;
        if (await DialogService.ShowMessageBox("Törlés", $"Biztosan törli: \"{item.Nev}\"?", yesText: "Törlés", cancelText: "Mégse") == true)
        {
            await KepzesService.DeleteAsync(item.Id);
            Snackbar.Add("Törölve.", Severity.Success);
            _lista = await KepzesService.GetAllAdminAsync();
        }
    }
}