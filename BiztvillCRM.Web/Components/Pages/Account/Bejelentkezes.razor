@page "/bejelentkezes"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Bejelentkezés - Biztovill CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudPaper Class="pa-8 ma-auto" Elevation="4" Style="width: 100%; max-width: 400px;">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Biztovill CRM</MudText>
        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">Bejelentkezés</MudText>

        <MudTextField @bind-Value="_email" Label="Email cím" 
                      InputType="InputType.Email" Required="true" Class="mb-3"
                      OnKeyUp="@OnEnterPressed" />
        
        <MudTextField @bind-Value="_password" Label="Jelszó" 
                      InputType="InputType.Password" Required="true" Class="mb-4"
                      OnKeyUp="@OnEnterPressed" />
        
        <MudCheckBox @bind-Value="_rememberMe" Label="Emlékezz rám" Color="Color.Primary" Class="mb-4" />
        
        <MudButton OnClick="BejelentkezesAsync" Variant="Variant.Filled" Color="Color.Primary" 
                   FullWidth="true" Disabled="_betoltes">
            @if (_betoltes)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Bejelentkezés
        </MudButton>
        
        @if (!string.IsNullOrEmpty(_hibaUzenet))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_hibaUzenet</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "hiba")]
    public string? HibaParam { get; set; }

    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _rememberMe;
    private bool _betoltes;
    private string? _hibaUzenet;

    protected override void OnParametersSet()
    {
        _hibaUzenet = HibaParam switch
        {
            "zarolt" => "A fiók ideiglenesen zárolva van.",
            "hibas" => "Hibás email cím vagy jelszó.",
            _ => null
        };
    }

    private async Task OnEnterPressed(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await BejelentkezesAsync();
        }
    }

    private async Task BejelentkezesAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _hibaUzenet = "Kérjük, töltse ki az összes mezőt.";
            return;
        }

        _betoltes = true;
        _hibaUzenet = null;

        try
        {
            await JS.InvokeVoidAsync("submitLoginForm", _email, _password, _rememberMe);
        }
        catch (Exception ex)
        {
            _hibaUzenet = $"Hiba történt: {ex.Message}";
            _betoltes = false;
        }
    }
}