@page "/bejelentkezes"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.EntityFrameworkCore
@inject SignInManager<Felhasznalo> SignInManager
@inject UserManager<Felhasznalo> UserManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IAntiforgery Antiforgery
@inject IConfiguration Configuration
@inject ILogger<Microsoft.AspNetCore.Components.ComponentBase> Logger

<PageTitle>Bejelentkezés - Biztovill CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudPaper Class="pa-8 ma-auto" Elevation="4" Style="width: 100%; max-width: 400px;">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Biztovill CRM</MudText>
        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">Bejelentkezés</MudText>

        <EditForm Model="_loginModel" OnValidSubmit="BejelentkezesAsync" FormName="login">
            <DataAnnotationsValidator />
            
            <MudTextField @bind-Value="_loginModel.Email" Label="Email cím" 
                          InputType="InputType.Email" Required="true" Class="mb-3" />
            
            <MudTextField @bind-Value="_loginModel.Password" Label="Jelszó" 
                          InputType="InputType.Password" Required="true" Class="mb-4" />
            
            <MudCheckBox @bind-Value="_loginModel.RememberMe" Label="Emlékezz rám" Color="Color.Primary" Class="mb-4" />
            
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                       FullWidth="true" Disabled="_betoltes">
                @if (_betoltes)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Bejelentkezés
            </MudButton>
        </EditForm>
        
        @if (!string.IsNullOrEmpty(_hibaUzenet))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_hibaUzenet</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "hiba")]
    public string? HibaParam { get; set; }
    private readonly LoginModel _loginModel = new();
    private bool _betoltes;
    private string? _hibaUzenet;
    private string _antiforgeryToken = string.Empty;

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
    protected override void OnParametersSet()
    {
        _hibaUzenet = HibaParam switch
        {
            "zarolt" => "A fiók ideiglenesen zárolva van.",
            "hibas" => "Hibás email cím vagy jelszó.",
            _ => null
        };
    }


    private async Task BejelentkezesAsync()
    {
        _betoltes = true;
        _hibaUzenet = null;

        try
        {
            var email = _loginModel.Email.Trim();

            // 0) Logoljuk az aktuális connection string-et (diagnosztika)
            var conn = Configuration.GetConnectionString("DefaultConnection") ?? "(no connection string)";
            Logger.LogInformation("Bejelentkezés: connection string = {Conn}", conn);
            Snackbar.Add("Connection: " + (conn.Length > 80 ? conn[..80] + "..." : conn), Severity.Info);

            // 1) Keressük a felhasználót email alapján
            var userByEmail = await UserManager.FindByEmailAsync(email);
            // 2) Ellenőrizzük FindByNameAsync is (ha a UserName és Email eltérhet)
            var userByName = await UserManager.FindByNameAsync(email);

            // 3) Közvetlen DB lekérdezés (UserManager.Users)
            var totalUsers = await UserManager.Users.CountAsync();
            var matchingByEmailCount = await UserManager.Users.Where(u => u.Email == email).CountAsync();
            var matchingByNormalizedEmailCount = await UserManager.Users.Where(u => u.NormalizedEmail == email.ToUpperInvariant()).CountAsync();

            // Log és rövid visszajelzés
            Logger.LogInformation("Users total: {Total}, byEmail: {ByEmail}, byNormalized: {ByNorm}", totalUsers, matchingByEmailCount, matchingByNormalizedEmailCount);

            if (userByEmail == null && userByName == null)
            {
                _hibaUzenet = "Felhasználó nem található.";
                Snackbar.Add($"Diagnosztika: totalUsers={totalUsers}, matchingByEmail={matchingByEmailCount}, matchingByNormalizedEmail={matchingByNormalizedEmailCount}", Severity.Error);
                return;
            }

            // Válasszuk ki a megtalált user-t (prefer email)
            var user = userByEmail ?? userByName!;

            // Ellenőrizzük az Aktiv mezőt
            if (!user.Aktiv)
            {
                _hibaUzenet = "A felhasználó inaktív. Lépj kapcsolatba a rendszergazdával.";
                Snackbar.Add(_hibaUzenet, Severity.Warning);
                return;
            }

            // Jelszó ellenőrzés
            await JS.InvokeVoidAsync("submitLoginForm",
     _loginModel.Email,
     _loginModel.Password,
     _loginModel.RememberMe);
        }
        catch (Exception ex)
        {
            _hibaUzenet = $"Hiba történt: {ex.Message}";
            Logger.LogError(ex, "Bejelentkezés hiba");
            Snackbar.Add(_hibaUzenet, Severity.Error);
        
            _betoltes = false;
        }
    }
}