@page "/hozzaferes-megtagadva"
@layout EmptyLayout

<PageTitle>Hozzáférés megtagadva - Biztovill CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Class="pa-8" Elevation="4" Style="width: 100%; max-width: 450px;">
        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h5">Hozzáférés megtagadva</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                Nincs jogosultsága az oldal megtekintéséhez.
            </MudText>
        </MudStack>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/">
            Vissza a főoldalra
        </MudButton>
    </MudPaper>
</MudContainer>