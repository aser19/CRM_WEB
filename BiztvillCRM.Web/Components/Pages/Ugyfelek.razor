@page "/ugyfelek"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Shared.Enums
@using BiztvillCRM.Services.Interfaces
@inject IUgyfelService UgyfelService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ITelephelyService TelephelyService
@inject ITenantService TenantService
@inject ICegService CegService

<PageTitle>Ügyfelek</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Ügyfelek</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses"
                      Label="Keresés (név, email, adószám)"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true"
                      Immediate="true"
                      OnClearButtonClick="() => _kereses = string.Empty"
                      Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="UjUgyfelMegnyitasa">
            Új ügyfél
        </MudButton>
    </MudStack>

    <MudDataGrid T="Ugyfel"
                 Items="_szurtUgyfelek"
                 Filterable="false"
                 SortMode="SortMode.Multiple"
                 Hover="true"
                 Striped="true"
                 Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="u => u.Nev" Title="Név" />
            <PropertyColumn Property="u => u.Adoszam" Title="Adószám" />
            <PropertyColumn Property="u => u.UgyfelTipus" Title="Típus" />
            <PropertyColumn Property="u => u.Email" Title="Email" />
            <PropertyColumn Property="u => u.Telefon" Title="Telefon" />
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Telephelyek" >
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Item.Telephelyek.Count db</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="() => SzerkesztessMegnyitasa(context.Item)"
                                       aria-label="Szerkesztés" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => TorlesMegerosites(context.Item)"
                                       aria-label="Törlés" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>Nincs megjeleníthető ügyfél.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Betöltés...</MudText>
        </LoadingContent>
    </MudDataGrid>
</MudPaper>

<!-- Ügyfél hozzáadása / szerkesztése dialógus -->
<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(_szerkesztesAlatt?.Id > 0 ? "Ügyfél szerkesztése" : "Új ügyfél hozzáadása")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                @if (_isAdmin)
                {
                    <MudItem xs="12">
                        <MudSelect T="int" @bind-Value="_kivalasztottCegId" Label="Cég *">
                            @foreach (var c in _cegek)
                            {
                                <MudSelectItem Value="@c.Id">@c.Nev</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Nev"
                                  Label="Név *"
                                  Required="true"
                                  RequiredError="A név megadása kötelező." />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="UgyfelTipus" @bind-Value="_szerkesztesAlatt.UgyfelTipus" Label="Típus">
                        @foreach (UgyfelTipus t in Enum.GetValues(typeof(UgyfelTipus)))
                        {
                            <MudSelectItem Value="@t">@t.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Adoszam" Label="Adószám" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Email" Label="Email" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Telefon" Label="Telefon" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Cim" Label="Cím" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa" Variant="Variant.Text">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">
            @(_mentes ? "Mentés..." : "Mentés")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Telephely hozzáadása dialógus -->
<MudDialog @bind-Visible="_telephelyDialogNyitva" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Új telephely hozzáadása</MudText>
    </TitleContent>
    <DialogContent>
        @if (_ujTelephely is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Nev" Label="Telephely neve *" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Cim" Label="Cím" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Kapcsolattarto" Label="Kapcsolattartó" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Telefon" Label="Telefon" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Email" Label="Email" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_ujTelephely.Aktiv" Label="Aktív" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _telephelyDialogNyitva = false">Mégse</MudButton>
        <MudButton OnClick="TelephelyMentesAsync" Color="Color.Primary" Variant="Variant.Filled">Mentés</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Ugyfel> _ugyfelek = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true;
    private bool _dialogNyitva = false;
    private bool _mentes = false;
    private Ugyfel? _szerkesztesAlatt;
    private bool _telephelyDialogNyitva = false;
    private Telephely? _ujTelephely;
    private int _kivalasztottCegId;
    private bool _isAdmin;
    private List<Ceg> _cegek = new();

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseButton = true
    };

    private IEnumerable<Ugyfel> _szurtUgyfelek =>
        string.IsNullOrWhiteSpace(_kereses)
            ? _ugyfelek
            : _ugyfelek.Where(u =>
                (u.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Email?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Adoszam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = TenantService.IsInRole(FelhasznaloSzerepkor.Admin);
        if (_isAdmin)
        {
            _cegek = await CegService.GetAllAsync(csakAktiv: false); // JAVÍTÁS: minden cég látható
        }
        await BetoltesAsync();
    }

    private async Task BetoltesAsync()
    {
        _betoltes = true;
        _ugyfelek = await UgyfelService.GetAllAsync();
        _betoltes = false;
    }

    private void UjUgyfelMegnyitasa()
    {
        var cegId = _isAdmin ? (_cegek.FirstOrDefault()?.Id ?? 0) : TenantService.GetCurrentCegId();
        _szerkesztesAlatt = new Ugyfel { Aktiv = true, CegId = cegId };
        _kivalasztottCegId = cegId;
        _dialogNyitva = true;
    }

    private void SzerkesztessMegnyitasa(Ugyfel ugyfel)
    {
        // Másolat készítése, hogy a megszakítás ne módosítsa az eredeti rekordot
        _szerkesztesAlatt = ugyfel.SekélyMásolat();
        _kivalasztottCegId = ugyfel.CegId;
        _dialogNyitva = true;
    }

    private void DialogBezarasa()
    {
        _dialogNyitva = false;
        _szerkesztesAlatt = null;
    }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null) return;
        
        Console.WriteLine($"[MentesAsync START] _isAdmin: {_isAdmin}, _kivalasztottCegId: {_kivalasztottCegId}, _szerkesztesAlatt.CegId: {_szerkesztesAlatt.CegId}");
        
        if (string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev))
        {
            Snackbar.Add("A név megadása kötelező!", Severity.Warning);
            Console.WriteLine("[MentesAsync] KILÉPÉS - Név üres!");
            return;
        }

        _mentes = true;
        bool ujUgyfel = _szerkesztesAlatt.Id == 0;
        
        try
        {
            // Admin esetén a kiválasztott céget állítjuk be
            if (_isAdmin)
            {
                Console.WriteLine($"[MentesAsync] Admin - CegId beállítása: {_kivalasztottCegId}");
                _szerkesztesAlatt.CegId = _kivalasztottCegId;
            }
            
            Console.WriteLine($"[MentesAsync] Mentés előtt - ujUgyfel: {ujUgyfel}, CegId: {_szerkesztesAlatt.CegId}");
            
            Ugyfel mentettUgyfel;
            if (ujUgyfel)
            {
                Console.WriteLine("[MentesAsync] CreateAsync hívása...");
                mentettUgyfel = await UgyfelService.CreateAsync(_szerkesztesAlatt);
                Console.WriteLine($"[MentesAsync] CreateAsync kész - Id: {mentettUgyfel.Id}, CegId: {mentettUgyfel.CegId}");
            }
            else
            {
                Console.WriteLine("[MentesAsync] UpdateAsync hívása...");
                await UgyfelService.UpdateAsync(_szerkesztesAlatt);
                mentettUgyfel = _szerkesztesAlatt;
                Console.WriteLine($"[MentesAsync] UpdateAsync kész - Id: {mentettUgyfel.Id}, CegId: {mentettUgyfel.CegId}");
            }

            Snackbar.Add("Sikeres mentés!", Severity.Success);
            DialogBezarasa();
            await BetoltesAsync();

            if (ujUgyfel)
            {
                await TelephelyKerdesAsync(mentettUgyfel);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MentesAsync] HIBA: {ex.Message}");
            Console.WriteLine($"[MentesAsync] Stack: {ex.StackTrace}");
            Snackbar.Add($"Hiba a mentés során: {ex.Message}", Severity.Error);
        }
        finally
        {
            _mentes = false;
        }
    }

    private async Task TelephelyKerdesAsync(Ugyfel ugyfel)
    {
        var result = await DialogService.ShowMessageBox(
            "Telephely rögzítése",
            "Szeretne telephelyet rögzíteni az ügyfélhez?",
            yesText: "Igen, ugyanazokkal az adatokkal",
            noText: "Igen, más adatokkal",
            cancelText: "Nem");

        if (result == true)
        {
            // Ugyanazokkal az adatokkal
            var telephely = new Telephely
            {
                UgyfelId = ugyfel.Id,
                Nev = ugyfel.Nev,
                Cim = ugyfel.Cim,
                Telefon = ugyfel.Telefon,
                Email = ugyfel.Email,
                Aktiv = true
            };
            await TelephelyService.CreateAsync(telephely);
            Snackbar.Add("Telephely rögzítve az ügyfél adataival!", Severity.Success);
            await BetoltesAsync();
        }
        else if (result == false)
        {
            // Más adatokkal - nyissuk meg a telephely dialógust
            _ujTelephely = new Telephely { UgyfelId = ugyfel.Id, Aktiv = true };
            _telephelyDialogNyitva = true;
        }
        // Ha cancel (null), akkor nem csinálunk semmit
    }

    private async Task TorlesMegerosites(Ugyfel ugyfel)
    {
        var kapcsolodo = await UgyfelService.GetKapcsolodoAdatokAsync(ugyfel.Id);

        if (kapcsolodo.VanKapcsolodoAdat)
        {
            var uzenet = $"A(z) \"{ugyfel.Nev}\" ügyfélnek hozzárendelt adatai vannak: {kapcsolodo.Osszefoglalas()}. Ezeket is kívánja törölni? [FIGYELEM] A törlés nem visszavonható!";

            var result = await DialogService.ShowMessageBox(
                "Törlés megerősítése",
                uzenet,
                yesText: "Igen, mindent törlök",
                cancelText: "Mégsem");

            if (result == true)
            {
                try
                {
                    await UgyfelService.DeleteWithRelatedDataAsync(ugyfel.Id);
                    Snackbar.Add($"Ügyfél és {kapcsolodo.Osszefoglalas()} törölve.", Severity.Success);
                    await BetoltesAsync();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Hiba a törlés során: {ex.Message}", Severity.Error);
                }
            }
        }
        else
        {
            var result = await DialogService.ShowMessageBox(
                "Törlés megerősítése",
                $"Biztosan törli a(z) \"{ugyfel.Nev}\" ügyfelet?",
                yesText: "Törlés",
                cancelText: "Mégse");

            if (result == true)
            {
                try
                {
                    await UgyfelService.DeleteAsync(ugyfel.Id);
                    Snackbar.Add("Ügyfél törölve.", Severity.Success);
                    await BetoltesAsync();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Hiba a törlés során: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private async Task TelephelyMentesAsync()
    {
        if (_ujTelephely is null || string.IsNullOrWhiteSpace(_ujTelephely.Nev))
        {
            Snackbar.Add("A telephely neve kötelező!", Severity.Warning);
            return;
        }

        try
        {
            await TelephelyService.CreateAsync(_ujTelephely);
            Snackbar.Add("Telephely sikeresen rögzítve!", Severity.Success);
            _telephelyDialogNyitva = false;
            _ujTelephely = null;
            await BetoltesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
    }
}
