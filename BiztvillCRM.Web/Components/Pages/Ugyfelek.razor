@page "/ugyfelek"
@rendermode InteractiveServer
@using BiztvillCRM.Shared.Models
@using BiztvillCRM.Shared.Enums
@using BiztvillCRM.Services.Interfaces
@inject IUgyfelService UgyfelService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ITelephelyService TelephelyService
@inject ITenantService TenantService
@inject ICegService CegService

<PageTitle>Ügyfelek</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Ügyfelek</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_kereses"
                      Label="Keresés (név, email, adószám)"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true"
                      Immediate="true"
                      OnClearButtonClick="() => _kereses = string.Empty"
                      Style="max-width:400px;" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="UjUgyfelMegnyitasa">
            Új ügyfél
        </MudButton>
    </MudStack>

    <MudDataGrid T="Ugyfel"
                 Items="_szurtUgyfelek"
                 Filterable="false"
                 SortMode="SortMode.Multiple"
                 Hover="true"
                 Striped="true"
                 Loading="_betoltes">
        <Columns>
            <PropertyColumn Property="u => u.Nev" Title="Név" />
            <PropertyColumn Property="u => u.Adoszam" Title="Adószám" />
            <PropertyColumn Property="u => u.UgyfelTipus" Title="Típus" />
            <TemplateColumn Title="Tevékenység">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        @if (context.Item.Tevekenyseg.HasFlag(TevekenysegTipus.VillanosMeres))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">Villamos</MudChip>
                        }
                        @if (context.Item.Tevekenyseg.HasFlag(TevekenysegTipus.Benzinkuttechnika))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">Benzinkút</MudChip>
                        }
                        @if (context.Item.Tevekenyseg.HasFlag(TevekenysegTipus.Munkavédelem))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Munkavédelem</MudChip>
                        }
                        @if (context.Item.Tevekenyseg == TevekenysegTipus.Nincs)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">-</MudChip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="u => u.Email" Title="Email" />
            <PropertyColumn Property="u => u.Telefon" Title="Telefon" />
            <TemplateColumn Title="Aktív">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Aktiv ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.Aktiv ? Color.Success : Color.Error)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Telephelyek">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Item.Telephelyek.Count db</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Műveletek" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="() => SzerkesztessMegnyitasa(context.Item)"
                                       aria-label="Szerkesztés" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => TorlesMegerosites(context.Item)"
                                       aria-label="Törlés" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>Nincs megjeleníthető ügyfél.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Betöltés...</MudText>
        </LoadingContent>
    </MudDataGrid>
</MudPaper>

<!-- Ügyfél hozzáadása / szerkesztése dialógus -->
<MudDialog @bind-Visible="_dialogNyitva" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(_szerkesztesAlatt?.Id > 0 ? "Ügyfél szerkesztése" : "Új ügyfél hozzáadása")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_szerkesztesAlatt is not null)
        {
            <MudGrid>
                @if (_isAdmin)
                {
                    <MudItem xs="12">
                        <MudSelect T="int" Value="_kivalasztottCegId" ValueChanged="OnCegValtozas" Label="Cég *">
                            @foreach (var c in _cegek)
                            {
                                <MudSelectItem Value="@c.Id">@c.Nev</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Nev"
                                  Label="Név *"
                                  Required="true"
                                  RequiredError="A név megadása kötelező." />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="UgyfelTipus" @bind-Value="_szerkesztesAlatt.UgyfelTipus" Label="Típus">
                        @foreach (UgyfelTipus t in Enum.GetValues(typeof(UgyfelTipus)))
                        {
                            <MudSelectItem Value="@t">@t.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <!-- Tevékenység választó -->
                <MudItem xs="12">
                    @if (_aktualisCegTevekenyseg != TevekenysegTipus.Nincs)
                    {
                        @if (CsakEgyTevekenyseg(_aktualisCegTevekenyseg))
                        {
                            <!-- Ha csak egy tevékenysége van a cégnek, csak megjelenítjük -->
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tevékenységi kör</MudText>
                                <MudStack Row="true" Spacing="1">
                                    @if (_aktualisCegTevekenyseg == TevekenysegTipus.VillanosMeres)
                                    {
                                        <MudChip T="string" Color="Color.Primary">Villamos mérés</MudChip>
                                    }
                                    else if (_aktualisCegTevekenyseg == TevekenysegTipus.Benzinkuttechnika)
                                    {
                                        <MudChip T="string" Color="Color.Secondary">Benzinkúttechnika</MudChip>
                                    }
                                    else if (_aktualisCegTevekenyseg == TevekenysegTipus.Munkavédelem)
                                    {
                                        <MudChip T="string" Color="Color.Warning">Munkavédelem</MudChip>
                                    }
                                </MudStack>
                            </MudStack>
                        }
                        else
                        {
                            <!-- Ha több tevékenysége van a cégnek, választható -->
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tevékenységi kör *</MudText>
                                <MudStack Row="true" Spacing="3">
                                    @if (_aktualisCegTevekenyseg.HasFlag(TevekenysegTipus.VillanosMeres))
                                    {
                                        <MudCheckBox T="bool"
                                                     Value="@_szerkesztesAlatt.Tevekenyseg.HasFlag(TevekenysegTipus.VillanosMeres)"
                                                     ValueChanged="@(v => OnTevekenysegValtozas(TevekenysegTipus.VillanosMeres, v))"
                                                     Label="Villamos mérés"
                                                     Color="Color.Primary" />
                                    }
                                    @if (_aktualisCegTevekenyseg.HasFlag(TevekenysegTipus.Benzinkuttechnika))
                                    {
                                        <MudCheckBox T="bool"
                                                     Value="@_szerkesztesAlatt.Tevekenyseg.HasFlag(TevekenysegTipus.Benzinkuttechnika)"
                                                     ValueChanged="@(v => OnTevekenysegValtozas(TevekenysegTipus.Benzinkuttechnika, v))"
                                                     Label="Benzinkúttechnika"
                                                     Color="Color.Secondary" />
                                    }
                                    @if (_aktualisCegTevekenyseg.HasFlag(TevekenysegTipus.Munkavédelem))
                                    {
                                        <MudCheckBox T="bool"
                                                     Value="@_szerkesztesAlatt.Tevekenyseg.HasFlag(TevekenysegTipus.Munkavédelem)"
                                                     ValueChanged="@(v => OnTevekenysegValtozas(TevekenysegTipus.Munkavédelem, v))"
                                                     Label="Munkavédelem"
                                                     Color="Color.Warning" />
                                    }
                                </MudStack>
                                @if (_szerkesztesAlatt.Tevekenyseg == TevekenysegTipus.Nincs && _validacioMutatasa)
                                {
                                    <MudText Color="Color.Error" Typo="Typo.caption">
                                        Legalább egy tevékenységi kör kiválasztása kötelező!
                                    </MudText>
                                }
                            </MudStack>
                        }
                    }
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Adoszam" Label="Adószám" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Email" Label="Email" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Telefon" Label="Telefon" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_szerkesztesAlatt.Cim" Label="Cím" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_szerkesztesAlatt.Aktiv" Label="Aktív" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DialogBezarasa" Variant="Variant.Text">Mégse</MudButton>
        <MudButton OnClick="MentesAsync" Color="Color.Primary" Variant="Variant.Filled" Disabled="_mentes">
            @(_mentes ? "Mentés..." : "Mentés")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Telephely hozzáadása dialógus -->
<MudDialog @bind-Visible="_telephelyDialogNyitva" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Új telephely hozzáadása</MudText>
    </TitleContent>
    <DialogContent>
        @if (_ujTelephely is not null)
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Nev" Label="Telephely neve *" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Cim" Label="Cím" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Kapcsolattarto" Label="Kapcsolattartó" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Telefon" Label="Telefon" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_ujTelephely.Email" Label="Email" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_ujTelephely.Aktiv" Label="Aktív" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _telephelyDialogNyitva = false">Mégse</MudButton>
        <MudButton OnClick="TelephelyMentesAsync" Color="Color.Primary" Variant="Variant.Filled">Mentés</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Ugyfel> _ugyfelek = new();
    private string _kereses = string.Empty;
    private bool _betoltes = true;
    private bool _dialogNyitva = false;
    private bool _mentes = false;
    private Ugyfel? _szerkesztesAlatt;
    private bool _telephelyDialogNyitva = false;
    private Telephely? _ujTelephely;
    private int _kivalasztottCegId;
    private bool _isAdmin;
    private List<Ceg> _cegek = new();
    private TevekenysegTipus _aktualisCegTevekenyseg = TevekenysegTipus.Nincs;
    private bool _validacioMutatasa = false;
    private Ceg? _sajatCeg;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseButton = true
    };

    private IEnumerable<Ugyfel> _szurtUgyfelek =>
        string.IsNullOrWhiteSpace(_kereses)
            ? _ugyfelek
            : _ugyfelek.Where(u =>
                (u.Nev?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Email?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Adoszam?.Contains(_kereses, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = TenantService.IsInRole(FelhasznaloSzerepkor.Admin);
        if (_isAdmin)
        {
            _cegek = await CegService.GetAllAsync(csakAktiv: false);
        }
        else
        {
            // Nem admin: saját cég betöltése
            var cegId = TenantService.GetCurrentCegId();
            _sajatCeg = await CegService.GetByIdAsync(cegId);
        }
        await BetoltesAsync();
    }

    private async Task BetoltesAsync()
    {
        _betoltes = true;
        _ugyfelek = await UgyfelService.GetAllAsync();
        _betoltes = false;
    }

    private void UjUgyfelMegnyitasa()
    {
        int cegId;
        if (_isAdmin)
        {
            cegId = _cegek.FirstOrDefault()?.Id ?? 0;
            _aktualisCegTevekenyseg = _cegek.FirstOrDefault()?.Tevekenyseg ?? TevekenysegTipus.Nincs;
        }
        else
        {
            cegId = TenantService.GetCurrentCegId();
            _aktualisCegTevekenyseg = _sajatCeg?.Tevekenyseg ?? TevekenysegTipus.Nincs;
        }

        // Ha csak egy tevékenysége van a cégnek, automatikusan beállítjuk
        var alapTevekenyseg = CsakEgyTevekenyseg(_aktualisCegTevekenyseg) 
            ? _aktualisCegTevekenyseg 
            : TevekenysegTipus.Nincs;

        _szerkesztesAlatt = new Ugyfel 
        { 
            Aktiv = true, 
            CegId = cegId,
            Tevekenyseg = alapTevekenyseg
        };
        _kivalasztottCegId = cegId;
        _validacioMutatasa = false;
        _dialogNyitva = true;
    }

    private void SzerkesztessMegnyitasa(Ugyfel ugyfel)
    {
        _szerkesztesAlatt = ugyfel.SekélyMásolat();
        _kivalasztottCegId = ugyfel.CegId;
        
        // Cég tevékenységének betöltése
        if (_isAdmin)
        {
            var ceg = _cegek.FirstOrDefault(c => c.Id == ugyfel.CegId);
            _aktualisCegTevekenyseg = ceg?.Tevekenyseg ?? TevekenysegTipus.Nincs;
        }
        else
        {
            _aktualisCegTevekenyseg = _sajatCeg?.Tevekenyseg ?? TevekenysegTipus.Nincs;
        }
        
        _validacioMutatasa = false;
        _dialogNyitva = true;
    }

    private void OnCegValtozas(int ujCegId)
    {
        _kivalasztottCegId = ujCegId;
        var ceg = _cegek.FirstOrDefault(c => c.Id == ujCegId);
        _aktualisCegTevekenyseg = ceg?.Tevekenyseg ?? TevekenysegTipus.Nincs;
        
        if (_szerkesztesAlatt != null)
        {
            _szerkesztesAlatt.CegId = ujCegId;
            
            // Ha csak egy tevékenysége van a cégnek, automatikusan beállítjuk
            if (CsakEgyTevekenyseg(_aktualisCegTevekenyseg))
            {
                _szerkesztesAlatt.Tevekenyseg = _aktualisCegTevekenyseg;
            }
            else
            {
                // Ha több van, reseteljük és újra kell választani
                _szerkesztesAlatt.Tevekenyseg = TevekenysegTipus.Nincs;
            }
        }
    }

    private void OnTevekenysegValtozas(TevekenysegTipus tipus, bool bekapcsol)
    {
        if (_szerkesztesAlatt == null) return;

        if (bekapcsol)
        {
            _szerkesztesAlatt.Tevekenyseg |= tipus;
        }
        else
        {
            _szerkesztesAlatt.Tevekenyseg &= ~tipus;
        }
    }

    private static bool CsakEgyTevekenyseg(TevekenysegTipus tevekenyseg)
    {
        // Csak akkor igaz, ha pontosan egy bit van beállítva (és nem nulla)
        return tevekenyseg != TevekenysegTipus.Nincs && 
               (tevekenyseg == TevekenysegTipus.VillanosMeres || 
                tevekenyseg == TevekenysegTipus.Benzinkuttechnika);
    }

    private void DialogBezarasa()
    {
        _dialogNyitva = false;
        _szerkesztesAlatt = null;
        _validacioMutatasa = false;
    }

    private async Task MentesAsync()
    {
        if (_szerkesztesAlatt is null) return;

        if (string.IsNullOrWhiteSpace(_szerkesztesAlatt.Nev))
        {
            Snackbar.Add("A név megadása kötelező!", Severity.Warning);
            return;
        }

        // Tevékenység validáció (ha a cégnek több tevékenysége van)
        if (!CsakEgyTevekenyseg(_aktualisCegTevekenyseg) && 
            _szerkesztesAlatt.Tevekenyseg == TevekenysegTipus.Nincs)
        {
            _validacioMutatasa = true;
            Snackbar.Add("Legalább egy tevékenységi kör kiválasztása kötelező!", Severity.Warning);
            return;
        }

        // Ha csak egy tevékenysége van a cégnek, automatikusan beállítjuk
        if (CsakEgyTevekenyseg(_aktualisCegTevekenyseg))
        {
            _szerkesztesAlatt.Tevekenyseg = _aktualisCegTevekenyseg;
        }

        _mentes = true;
        bool ujUgyfel = _szerkesztesAlatt.Id == 0;

        try
        {
            if (_isAdmin)
            {
                _szerkesztesAlatt.CegId = _kivalasztottCegId;
            }

            Ugyfel mentettUgyfel;
            if (ujUgyfel)
            {
                mentettUgyfel = await UgyfelService.CreateAsync(_szerkesztesAlatt);
            }
            else
            {
                await UgyfelService.UpdateAsync(_szerkesztesAlatt);
                mentettUgyfel = _szerkesztesAlatt;
            }

            Snackbar.Add("Sikeres mentés!", Severity.Success);
            DialogBezarasa();
            await BetoltesAsync();

            if (ujUgyfel)
            {
                await TelephelyKerdesAsync(mentettUgyfel);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba a mentés során: {ex.Message}", Severity.Error);
        }
        finally
        {
            _mentes = false;
        }
    }

    private async Task TelephelyKerdesAsync(Ugyfel ugyfel)
    {
        var result = await DialogService.ShowMessageBox(
            "Telephely rögzítése",
            "Szeretne telephelyet rögzíteni az ügyfélhez?",
            yesText: "Igen, ugyanazokkal az adatokkal",
            noText: "Igen, más adatokkal",
            cancelText: "Nem");

        if (result == true)
        {
            // Automatikus telephely létrehozás az ügyfél adataival
            var telephely = new Telephely
            {
                Nev = ugyfel.Nev + " - Székhely",
                Cim = ugyfel.Cim,
                Telefon = ugyfel.Telefon,
                Email = ugyfel.Email,
                UgyfelId = ugyfel.Id,
                Aktiv = true
            };
            await TelephelyService.CreateAsync(telephely);
            Snackbar.Add("Telephely automatikusan létrehozva!", Severity.Success);
            await BetoltesAsync();
        }
        else if (result == false)
        {
            // Manuális telephely létrehozás
            _ujTelephely = new Telephely { UgyfelId = ugyfel.Id, Aktiv = true };
            _telephelyDialogNyitva = true;
        }
    }

    private async Task TelephelyMentesAsync()
    {
        if (_ujTelephely is null || string.IsNullOrWhiteSpace(_ujTelephely.Nev))
        {
            Snackbar.Add("A telephely neve kötelező!", Severity.Warning);
            return;
        }

        try
        {
            await TelephelyService.CreateAsync(_ujTelephely);
            Snackbar.Add("Telephely sikeresen létrehozva!", Severity.Success);
            _telephelyDialogNyitva = false;
            _ujTelephely = null;
            await BetoltesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hiba: {ex.Message}", Severity.Error);
        }
    }

    private async Task TorlesMegerosites(Ugyfel ugyfel)
    {
        // Kapcsolódó adatok lekérdezése
        var kapcsolodo = await UgyfelService.GetKapcsolodoAdatokAsync(ugyfel.Id);
        
        string uzenet;
        if (kapcsolodo.VanKapcsolodoAdat)
        {
            var reszletek = new List<string>();
            if (kapcsolodo.Telephelyek > 0) reszletek.Add($"{kapcsolodo.Telephelyek} telephely");
            if (kapcsolodo.Meresek > 0) reszletek.Add($"{kapcsolodo.Meresek} mérés");
            if (kapcsolodo.Hitelesitesek > 0) reszletek.Add($"{kapcsolodo.Hitelesitesek} hitelesítés");
            if (kapcsolodo.MunkavedelmiOktatasok > 0) reszletek.Add($"{kapcsolodo.MunkavedelmiOktatasok} munkavédelmi oktatás");
            if (kapcsolodo.Eszkozok > 0) reszletek.Add($"{kapcsolodo.Eszkozok} eszköz");
            if (kapcsolodo.Tanusitvanyok > 0) reszletek.Add($"{kapcsolodo.Tanusitvanyok} tanúsítvány");
            if (kapcsolodo.Karbantartasok > 0) reszletek.Add($"{kapcsolodo.Karbantartasok} karbantartás");
            
            uzenet = $"A(z) \"{ugyfel.Nev}\" ügyfélhez az alábbi adatok tartoznak:\n\n" +
                     $"• {string.Join("\n• ", reszletek)}\n\n" +
                     "Biztosan törölni szeretné az ügyfelet és az összes kapcsolódó adatot?";
        }
        else
        {
            uzenet = $"Biztosan törölni szeretné a(z) \"{ugyfel.Nev}\" nevű ügyfelet?";
        }

        var result = await DialogService.ShowMessageBox(
            "Ügyfél törlése",
            uzenet,
            yesText: kapcsolodo.VanKapcsolodoAdat ? "Igen, töröljön mindent" : "Törlés",
            cancelText: "Mégse");

        if (result == true)
        {
            try
            {
                await UgyfelService.DeleteWithRelatedDataAsync(ugyfel.Id);
                Snackbar.Add("Az ügyfél és az összes kapcsolódó adat sikeresen törölve.", Severity.Success);
                await BetoltesAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Hiba a törlés során: {ex.Message}", Severity.Error);
            }
        }
    }
}
