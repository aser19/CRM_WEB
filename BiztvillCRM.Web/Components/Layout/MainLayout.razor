@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <AuthorizeView>
        <Authorized>
            <MudAppBar Elevation="1" Color="Color.Primary">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-3">Biztovill CRM</MudText>
                <MudSpacer />
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit" OnClick="@ToggleDarkMode" />
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" 
                               OnClick="Kijelentkezes" Title="Kijelentkezés" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1565C0",
            Secondary = "#FF6F00",
            AppbarBackground = "#1565C0",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            DrawerBackground = "#FAFAFA",
            DrawerText = "#424242",
            Success = "#2E7D32",
            Warning = "#F57F17",
            Error = "#C62828",
            Info = "#0277BD"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#42A5F5",
            Secondary = "#FFB74D",
            AppbarBackground = "#1E1E1E",
            Background = "#121212",
            Surface = "#1E1E1E",
            DrawerBackground = "#1E1E1E",
            DrawerText = "#E0E0E0"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    
    private void Kijelentkezes()
    {
        Navigation.NavigateTo("/kijelentkezes", forceLoad: true);
    }
}